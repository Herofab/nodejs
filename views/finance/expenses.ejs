<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="bi bi-receipt me-2"></i>Expense Management
                    </h2>
                    <p class="text-muted">Track business expenses and operational costs</p>
                </div>
                <div class="btn-group">
                    <a href="/finance/dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
                    </a>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
                        <i class="bi bi-plus-lg me-1"></i>Add Expense
                    </button>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%); color: white;">
                            <i class="bi bi-credit-card fs-1 mb-2"></i>
                            <% const totalExpenses = expenses.reduce((sum, exp) => sum + parseFloat(exp.amount), 0); %>
                            <h3 class="card-title mb-1">$<%= totalExpenses.toFixed(2) %></h3>
                            <p class="card-text opacity-75">Total Expenses</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #6610f2 0%, #6f42c1 100%); color: white;">
                            <i class="bi bi-receipt-cutoff fs-1 mb-2"></i>
                            <h3 class="card-title mb-1"><%= expenses.length %></h3>
                            <p class="card-text opacity-75">Total Transactions</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                            <i class="bi bi-calendar-month fs-1 mb-2"></i>
                            <% const thisMonth = new Date().toISOString().slice(0, 7); %>
                            <% const monthlyExpenses = expenses.filter(exp => exp.transaction_date.slice(0, 7) === thisMonth).reduce((sum, exp) => sum + parseFloat(exp.amount), 0); %>
                            <h3 class="card-title mb-1">$<%= monthlyExpenses.toFixed(2) %></h3>
                            <p class="card-text opacity-75">This Month</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Expenses -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>Recent Expenses
                    </h5>
                    <span class="badge bg-primary"><%= expenses.length %> transactions</span>
                </div>
                <div class="card-body p-0">
                    <% if (expenses.length > 0) { %>
                    <!-- Search Box -->
                    <div class="p-3 border-bottom">
                        <input type="text" id="searchExpenses" class="form-control" placeholder="Search expenses...">
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="expensesTable">
                            <thead class="table-dark">
                                <tr>
                                    <th><i class="bi bi-calendar me-1"></i>Date</th>
                                    <th><i class="bi bi-tag me-1"></i>Category</th>
                                    <th><i class="bi bi-file-text me-1"></i>Description</th>
                                    <th><i class="bi bi-cash me-1"></i>Amount</th>
                                    <th><i class="bi bi-person me-1"></i>Added By</th>
                                    <th><i class="bi bi-gear me-1"></i>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% expenses.forEach(expense => { %>
                                <tr>
                                    <td>
                                        <%= new Date(expense.transaction_date).toLocaleDateString() %>
                                        <br>
                                        <small class="text-muted">
                                            <%= new Date(expense.created_at).toLocaleTimeString() %>
                                        </small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary"><%= expense.category %></span>
                                    </td>
                                    <td>
                                        <%= expense.description || 'No description' %>
                                    </td>
                                    <td>
                                        <h6 class="text-danger mb-0">-$<%= parseFloat(expense.amount).toFixed(2) %></h6>
                                    </td>
                                    <td>
                                        <small><%= expense.created_by_email || 'System' %></small>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="tooltip" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-receipt text-muted" style="font-size: 4rem;"></i>
                        <h4 class="text-muted mt-3">No Expenses Recorded</h4>
                        <p class="text-muted">Start tracking your business expenses by adding your first expense.</p>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
                            <i class="bi bi-plus-lg me-1"></i>Add First Expense
                        </button>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Expense Modal -->
<div class="modal fade" id="addExpenseModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Add Expense
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/finance/expenses">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="category" class="form-label">Category <span class="text-danger">*</span></label>
                                <select class="form-select" name="category" required>
                                    <option value="">Select category</option>
                                    <% categories.forEach(cat => { %>
                                    <option value="<%= cat.category_name %>"><%= cat.category_name %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="amount" class="form-label">Amount <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" name="amount" step="0.01" min="0" required>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="description" class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="description" rows="3" required 
                                  placeholder="Describe the expense..."></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="payment_method" class="form-label">Payment Method</label>
                                <select class="form-select" name="payment_method">
                                    <option value="cash">Cash</option>
                                    <option value="card">Credit/Debit Card</option>
                                    <option value="bank_transfer">Bank Transfer</option>
                                    <option value="check">Check</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="transaction_date" class="form-label">Date</label>
                                <input type="date" class="form-control" name="transaction_date" 
                                       value="<%= new Date().toISOString().split('T')[0] %>">
                            </div>
                        </div>
                    </div>

                    <!-- Employee Selection (for salary expenses) -->
                    <div class="mb-3" id="employeeSection" style="display: none;">
                        <label class="form-label">Employee</label>
                        <div class="row">
                            <div class="col-md-6">
                                <select class="form-select" name="employee_type" id="employeeType">
                                    <option value="">Select type</option>
                                    <option value="staff">Staff</option>
                                    <option value="driver">Driver</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <select class="form-select" name="employee_id" id="employeeSelect">
                                    <option value="">Select employee</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-check-lg me-1"></i>Add Expense
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.card {
    border-radius: 12px;
    transition: transform 0.2s ease-in-out;
}

.table thead th {
    border: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85em;
    letter-spacing: 0.5px;
}

.table tbody tr:hover {
    background-color: #f8f9fa !important;
}

.btn {
    border-radius: 8px;
    font-weight: 500;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Search functionality
    const searchInput = document.getElementById('searchExpenses');
    if (searchInput) {
        searchInput.addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            const rows = document.querySelectorAll('#expensesTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    }

    // Category change handler
    const categorySelect = document.querySelector('select[name="category"]');
    const employeeSection = document.getElementById('employeeSection');
    
    if (categorySelect) {
        categorySelect.addEventListener('change', function() {
            if (this.value.includes('Salary')) {
                employeeSection.style.display = 'block';
            } else {
                employeeSection.style.display = 'none';
            }
        });
    }

    // Initialize tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>