<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="bi bi-cash-coin me-2"></i>Payment Collection
                    </h2>
                    <p class="text-muted">Collect payments for delivered orders</p>
                </div>
                <div class="btn-group">
                    <a href="/finance/dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
                    </a>
                    <button class="btn btn-primary" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i>Print List
                    </button>
                </div>
            </div>

            <!-- Summary Card -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%); color: white;">
                            <i class="bi bi-exclamation-triangle-fill fs-1 mb-2"></i>
                            <h3 class="card-title mb-1"><%= pendingPayments.length %></h3>
                            <p class="card-text opacity-75">Pending Payments</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                            <i class="bi bi-cash-stack fs-1 mb-2"></i>
                            <% const totalPending = pendingPayments.reduce((sum, p) => sum + parseFloat(p.total_amount), 0); %>
                            <h3 class="card-title mb-1">$<%= totalPending.toFixed(2) %></h3>
                            <p class="card-text opacity-75">Total Amount Due</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #6610f2 0%, #6f42c1 100%); color: white;">
                            <i class="bi bi-clock-history fs-1 mb-2"></i>
                            <% const oldestPayment = pendingPayments.length > 0 ? Math.max(...pendingPayments.map(p => Math.floor((new Date() - new Date(p.actual_delivery_time)) / (1000 * 60 * 60 * 24)))) : 0; %>
                            <h3 class="card-title mb-1"><%= oldestPayment %></h3>
                            <p class="card-text opacity-75">Days Oldest Due</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pending Payments Table -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-list-check me-2"></i>Pending Payments
                    </h5>
                </div>
                <div class="card-body p-0">
                    <% if (pendingPayments.length > 0) { %>
                    <!-- Search Box -->
                    <div class="p-3 border-bottom">
                        <input type="text" id="searchPayments" class="form-control" placeholder="Search orders, customers, or drivers...">
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="paymentsTable">
                            <thead class="table-dark">
                                <tr>
                                    <th><i class="bi bi-hash me-1"></i>Order #</th>
                                    <th><i class="bi bi-person me-1"></i>Customer</th>
                                    <th><i class="bi bi-telephone me-1"></i>Contact</th>
                                    <th><i class="bi bi-bottle me-1"></i>Items</th>
                                    <th><i class="bi bi-cash me-1"></i>Amount</th>
                                    <th><i class="bi bi-truck me-1"></i>Driver</th>
                                    <th><i class="bi bi-calendar me-1"></i>Delivered</th>
                                    <th><i class="bi bi-gear me-1"></i>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% pendingPayments.forEach(payment => { %>
                                <tr>
                                    <td>
                                        <strong class="text-primary"><%= payment.order_number %></strong>
                                    </td>
                                    <td>
                                        <div>
                                            <strong><%= payment.customer_name %></strong>
                                        </div>
                                    </td>
                                    <td>
                                        <% if (payment.phone_primary) { %>
                                        <a href="tel:<%= payment.phone_primary %>" class="text-decoration-none">
                                            <i class="bi bi-telephone me-1"></i><%= payment.phone_primary %>
                                        </a>
                                        <% } else { %>
                                        <span class="text-muted">No phone</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <%= payment.quantity_per_delivery %> × <%= payment.bottle_type %>
                                        </small>
                                    </td>
                                    <td>
                                        <h5 class="text-success mb-0">$<%= parseFloat(payment.total_amount).toFixed(2) %></h5>
                                    </td>
                                    <td>
                                        <%= payment.driver_name || 'N/A' %>
                                    </td>
                                    <td>
                                        <% const deliveredDate = new Date(payment.actual_delivery_time); %>
                                        <% const daysAgo = Math.floor((new Date() - deliveredDate) / (1000 * 60 * 60 * 24)); %>
                                        <%= deliveredDate.toLocaleDateString() %>
                                        <br>
                                        <small class="<%= daysAgo > 7 ? 'text-danger' : daysAgo > 3 ? 'text-warning' : 'text-muted' %>">
                                            <%= daysAgo %> days ago
                                        </small>
                                    </td>
                                    <td>
                                        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#collectPaymentModal"
                                                data-assignment-id="<%= payment.assignment_id %>"
                                                data-order-number="<%= payment.order_number %>"
                                                data-customer-name="<%= payment.customer_name %>"
                                                data-amount="<%= payment.total_amount %>">
                                            <i class="bi bi-cash me-1"></i>Collect
                                        </button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                        <h4 class="text-success mt-3">All Payments Collected!</h4>
                        <p class="text-muted">There are no pending payments at this time.</p>
                        <a href="/finance/dashboard" class="btn btn-primary">
                            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
                        </a>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment Collection Modal -->
<div class="modal fade" id="collectPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-cash-coin me-2"></i>Collect Payment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="collectPaymentForm" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Order Details</label>
                        <div class="card bg-light">
                            <div class="card-body">
                                <p class="mb-1"><strong>Order #:</strong> <span id="modalOrderNumber"></span></p>
                                <p class="mb-1"><strong>Customer:</strong> <span id="modalCustomerName"></span></p>
                                <p class="mb-0"><strong>Amount Due:</strong> $<span id="modalAmount"></span></p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="payment_method" class="form-label">Payment Method <span class="text-danger">*</span></label>
                        <select class="form-select" id="payment_method" name="payment_method" required>
                            <option value="">Select payment method</option>
                            <option value="cash">Cash</option>
                            <option value="card">Credit/Debit Card</option>
                            <option value="bank_transfer">Bank Transfer</option>
                            <option value="check">Check</option>
                            <option value="mobile_payment">Mobile Payment</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="payment_amount" class="form-label">Amount Received</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" id="payment_amount" name="payment_amount" 
                                   step="0.01" min="0" placeholder="Leave blank for full amount">
                        </div>
                        <small class="form-text text-muted">Leave blank to collect the full amount due</small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="payment_notes" class="form-label">Notes (Optional)</label>
                        <textarea class="form-control" id="payment_notes" name="payment_notes" rows="3" 
                                  placeholder="Add any notes about the payment..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Collect Payment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.card {
    border-radius: 12px;
    transition: transform 0.2s ease-in-out;
}

.table thead th {
    border: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85em;
    letter-spacing: 0.5px;
}

.table tbody tr:hover {
    background-color: #f8f9fa !important;
}

.btn {
    border-radius: 8px;
    font-weight: 500;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Search functionality
    const searchInput = document.getElementById('searchPayments');
    if (searchInput) {
        searchInput.addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            const rows = document.querySelectorAll('#paymentsTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    }

    // Payment collection modal
    const collectModal = document.getElementById('collectPaymentModal');
    if (collectModal) {
        collectModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const assignmentId = button.getAttribute('data-assignment-id');
            const orderNumber = button.getAttribute('data-order-number');
            const customerName = button.getAttribute('data-customer-name');
            const amount = button.getAttribute('data-amount');

            // Update modal content
            document.getElementById('modalOrderNumber').textContent = orderNumber;
            document.getElementById('modalCustomerName').textContent = customerName;
            document.getElementById('modalAmount').textContent = parseFloat(amount).toFixed(2);
            
            // Set form action
            const form = document.getElementById('collectPaymentForm');
            form.action = `/finance/payments/${assignmentId}/collect`;
            
            // Set default amount
            document.getElementById('payment_amount').placeholder = `Full amount: $${parseFloat(amount).toFixed(2)}`;
        });
    }
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>