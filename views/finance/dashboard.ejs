<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="bi bi-graph-up me-2"></i>Financial Management Dashboard
                    </h2>
                    <p class="text-muted">Monitor revenue, expenses, and business performance</p>
                </div>
                <div class="btn-group">
                    <a href="/finance/payments" class="btn btn-success">
                        <i class="bi bi-cash-coin me-1"></i>Collect Payments
                    </a>
                    <a href="/finance/reports" class="btn btn-info">
                        <i class="bi bi-graph-up me-1"></i>Reports
                    </a>
                </div>
            </div>

            <!-- Financial Overview Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                            <i class="bi bi-cash-stack fs-1 mb-2"></i>
                            <h4 class="card-title mb-1">$<%= (overview.total_revenue || 0).toLocaleString() %></h4>
                            <p class="card-text opacity-75">Total Revenue (30 days)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%); color: white;">
                            <i class="bi bi-credit-card fs-1 mb-2"></i>
                            <h4 class="card-title mb-1">$<%= (overview.total_expenses_amount || 0).toLocaleString() %></h4>
                            <p class="card-text opacity-75">Total Expenses (30 days)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%); color: white;">
                            <i class="bi bi-clock-history fs-1 mb-2"></i>
                            <h4 class="card-title mb-1">$<%= (overview.pending_revenue || 0).toLocaleString() %></h4>
                            <p class="card-text opacity-75">Pending Payments</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #6610f2 0%, #6f42c1 100%); color: white;">
                            <i class="bi bi-graph-up fs-1 mb-2"></i>
                            <% const profit = (overview.total_revenue || 0) - (overview.total_expenses_amount || 0); %>
                            <h4 class="card-title mb-1">$<%= profit.toLocaleString() %></h4>
                            <p class="card-text opacity-75">Net Profit (30 days)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="bi bi-lightning-charge me-2"></i>Quick Actions
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <a href="/finance/payments" class="btn btn-outline-success w-100">
                                        <i class="bi bi-cash-coin d-block fs-3 mb-2"></i>
                                        Collect Payment
                                    </a>
                                </div>
                                <div class="col-6 mb-3">
                                    <a href="/finance/expenses" class="btn btn-outline-danger w-100">
                                        <i class="bi bi-receipt d-block fs-3 mb-2"></i>
                                        Add Expense
                                    </a>
                                </div>
                                <div class="col-6">
                                    <a href="/finance/packages" class="btn btn-outline-info w-100">
                                        <i class="bi bi-box-seam d-block fs-3 mb-2"></i>
                                        Monthly Packages
                                    </a>
                                </div>
                                <div class="col-6">
                                    <a href="/finance/reports" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-graph-up d-block fs-3 mb-2"></i>
                                        View Reports
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="bi bi-box-seam me-2"></i>Monthly Packages Overview
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-4">
                                    <h4 class="text-primary"><%= packageOverview.total_packages || 0 %></h4>
                                    <small class="text-muted">Active Packages</small>
                                </div>
                                <div class="col-4">
                                    <h4 class="text-success">$<%= (packageOverview.total_monthly_revenue || 0).toLocaleString() %></h4>
                                    <small class="text-muted">Monthly Revenue</small>
                                </div>
                                <div class="col-4">
                                    <h4 class="text-warning"><%= packageOverview.overdue_packages || 0 %></h4>
                                    <small class="text-muted">Overdue</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pending Payments -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Pending Payments
                            </h5>
                            <span class="badge bg-warning text-dark"><%= pendingPayments.length %> pending</span>
                        </div>
                        <div class="card-body p-0">
                            <% if (pendingPayments.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Order #</th>
                                            <th>Customer</th>
                                            <th>Amount</th>
                                            <th>Delivered</th>
                                            <th>Driver</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% pendingPayments.slice(0, 5).forEach(payment => { %>
                                        <tr>
                                            <td><strong><%= payment.order_number %></strong></td>
                                            <td><%= payment.customer_name %></td>
                                            <td class="text-success">$<%= parseFloat(payment.total_amount).toFixed(2) %></td>
                                            <td>
                                                <small class="text-muted">
                                                    <%= new Date(payment.actual_delivery_time).toLocaleDateString() %>
                                                </small>
                                            </td>
                                            <td><%= payment.driver_name || 'N/A' %></td>
                                            <td>
                                                <a href="/finance/payments" class="btn btn-sm btn-success">
                                                    <i class="bi bi-cash me-1"></i>Collect
                                                </a>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <% if (pendingPayments.length > 5) { %>
                            <div class="card-footer text-center">
                                <a href="/finance/payments" class="btn btn-outline-primary">
                                    View All <%= pendingPayments.length %> Pending Payments
                                </a>
                            </div>
                            <% } %>
                            <% } else { %>
                            <div class="text-center py-4">
                                <i class="bi bi-check-circle-fill text-success fs-1"></i>
                                <p class="text-muted mt-2">All payments are up to date!</p>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Transactions -->
            <div class="row">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-clock-history me-2"></i>Recent Transactions
                            </h5>
                            <a href="/finance/reports" class="btn btn-sm btn-outline-primary">View All</a>
                        </div>
                        <div class="card-body p-0">
                            <% if (recentTransactions.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th>Category</th>
                                            <th>Description</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% recentTransactions.forEach(transaction => { %>
                                        <tr>
                                            <td>
                                                <small><%= new Date(transaction.transaction_date).toLocaleDateString() %></small>
                                            </td>
                                            <td>
                                                <% if (transaction.transaction_type === 'income') { %>
                                                <span class="badge bg-success">Income</span>
                                                <% } else { %>
                                                <span class="badge bg-danger">Expense</span>
                                                <% } %>
                                            </td>
                                            <td><%= transaction.category %></td>
                                            <td>
                                                <small><%= transaction.description || 'No description' %></small>
                                            </td>
                                            <td class="<%= transaction.transaction_type === 'income' ? 'text-success' : 'text-danger' %>">
                                                <%= transaction.transaction_type === 'income' ? '+' : '-' %>$<%= parseFloat(transaction.amount).toFixed(2) %>
                                            </td>
                                            <td>
                                                <span class="badge bg-<%= transaction.payment_status === 'completed' ? 'success' : 'warning' %>">
                                                    <%= transaction.payment_status %>
                                                </span>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <% } else { %>
                            <div class="text-center py-4">
                                <i class="bi bi-receipt text-muted fs-1"></i>
                                <p class="text-muted mt-2">No recent transactions</p>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.card {
    border-radius: 12px;
    transition: transform 0.2s ease-in-out;
}

.card:hover {
    transform: translateY(-2px);
}

.btn {
    border-radius: 8px;
    font-weight: 500;
}

.table thead th {
    border: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85em;
    letter-spacing: 0.5px;
}

.badge {
    font-size: 0.8em;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>