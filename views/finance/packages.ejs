<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="bi bi-box-seam me-2"></i>Monthly Packages
                    </h2>
                    <p class="text-muted">Manage customer subscription packages and billing</p>
                </div>
                <div class="btn-group">
                    <a href="/finance/dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
                    </a>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPackageModal">
                        <i class="bi bi-plus-lg me-1"></i>Create Package
                    </button>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                            <i class="bi bi-check-circle fs-1 mb-2"></i>
                            <% const activePackages = packages.filter(pkg => pkg.status === 'active'); %>
                            <h3 class="card-title mb-1"><%= activePackages.length %></h3>
                            <p class="card-text opacity-75">Active Packages</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%); color: white;">
                            <i class="bi bi-clock fs-1 mb-2"></i>
                            <% const pendingPackages = packages.filter(pkg => pkg.status === 'pending'); %>
                            <h3 class="card-title mb-1"><%= pendingPackages.length %></h3>
                            <p class="card-text opacity-75">Pending Billing</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%); color: white;">
                            <i class="bi bi-exclamation-triangle fs-1 mb-2"></i>
                            <% const overduePackages = packages.filter(pkg => pkg.status === 'overdue'); %>
                            <h3 class="card-title mb-1"><%= overduePackages.length %></h3>
                            <p class="card-text opacity-75">Overdue</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #6610f2 0%, #6f42c1 100%); color: white;">
                            <i class="bi bi-cash-stack fs-1 mb-2"></i>
                            <% const totalRevenue = packages.reduce((sum, pkg) => sum + parseFloat(pkg.package_amount), 0); %>
                            <h3 class="card-title mb-1">$<%= totalRevenue.toFixed(2) %></h3>
                            <p class="card-text opacity-75">Total Value</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Packages List -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>Customer Packages
                    </h5>
                    <span class="badge bg-primary"><%= packages.length %> packages</span>
                </div>
                <div class="card-body p-0">
                    <% if (packages.length > 0) { %>
                    <!-- Search Box -->
                    <div class="p-3 border-bottom">
                        <input type="text" id="searchPackages" class="form-control" placeholder="Search packages...">
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="packagesTable">
                            <thead class="table-dark">
                                <tr>
                                    <th><i class="bi bi-person me-1"></i>Customer</th>
                                    <th><i class="bi bi-box me-1"></i>Package Type</th>
                                    <th><i class="bi bi-cash me-1"></i>Amount</th>
                                    <th><i class="bi bi-calendar me-1"></i>Billing Period</th>
                                    <th><i class="bi bi-activity me-1"></i>Status</th>
                                    <th><i class="bi bi-calendar-check me-1"></i>Next Due</th>
                                    <th><i class="bi bi-gear me-1"></i>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% packages.forEach(package => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2">
                                                <%= package.customer_name ? package.customer_name.charAt(0).toUpperCase() : 'C' %>
                                            </div>
                                            <div>
                                                <h6 class="mb-0"><%= package.customer_name %></h6>
                                                <small class="text-muted">ID: <%= package.customer_id %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info"><%= package.package_type %></span>
                                        <br>
                                        <small class="text-muted"><%= package.description || 'No description' %></small>
                                    </td>
                                    <td>
                                        <h6 class="text-success mb-0">$<%= parseFloat(package.package_amount).toFixed(2) %></h6>
                                    </td>
                                    <td>
                                        <%= new Date(package.start_date).toLocaleDateString() %>
                                        <br>
                                        <small class="text-muted">to <%= new Date(package.end_date).toLocaleDateString() %></small>
                                    </td>
                                    <td>
                                        <% let statusClass = 'bg-secondary'; %>
                                        <% if (package.status === 'active') statusClass = 'bg-success'; %>
                                        <% if (package.status === 'pending') statusClass = 'bg-warning'; %>
                                        <% if (package.status === 'overdue') statusClass = 'bg-danger'; %>
                                        <% if (package.status === 'cancelled') statusClass = 'bg-dark'; %>
                                        <span class="badge <%= statusClass %>"><%= package.status.toUpperCase() %></span>
                                    </td>
                                    <td>
                                        <% if (package.next_billing_date) { %>
                                            <%= new Date(package.next_billing_date).toLocaleDateString() %>
                                            <br>
                                            <% const daysUntil = Math.ceil((new Date(package.next_billing_date) - new Date()) / (1000 * 60 * 60 * 24)); %>
                                            <small class="<%= daysUntil < 0 ? 'text-danger' : (daysUntil <= 7 ? 'text-warning' : 'text-muted') %>">
                                                <%= daysUntil < 0 ? Math.abs(daysUntil) + ' days overdue' : (daysUntil === 0 ? 'Due today' : daysUntil + ' days') %>
                                            </small>
                                        <% } else { %>
                                            <span class="text-muted">Not set</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <% if (package.status === 'pending' || package.status === 'overdue') { %>
                                            <button class="btn btn-outline-success" onclick="collectPayment('<%= package.id %>')" 
                                                    data-bs-toggle="tooltip" title="Collect Payment">
                                                <i class="bi bi-cash"></i>
                                            </button>
                                            <% } %>
                                            <button class="btn btn-outline-primary" data-bs-toggle="tooltip" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-outline-warning" data-bs-toggle="tooltip" title="Edit Package">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-box-seam text-muted" style="font-size: 4rem;"></i>
                        <h4 class="text-muted mt-3">No Packages Created</h4>
                        <p class="text-muted">Create monthly packages for customers with recurring billing.</p>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPackageModal">
                            <i class="bi bi-plus-lg me-1"></i>Create First Package
                        </button>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Package Modal -->
<div class="modal fade" id="addPackageModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Create Monthly Package
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/finance/packages">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="customer_id" class="form-label">Customer <span class="text-danger">*</span></label>
                                <select class="form-select" name="customer_id" required>
                                    <option value="">Select customer</option>
                                    <% customers.forEach(customer => { %>
                                    <option value="<%= customer.id %>"><%= customer.name %> - <%= customer.email %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="package_type" class="form-label">Package Type <span class="text-danger">*</span></label>
                                <select class="form-select" name="package_type" required>
                                    <option value="">Select type</option>
                                    <option value="Basic">Basic Package</option>
                                    <option value="Premium">Premium Package</option>
                                    <option value="Corporate">Corporate Package</option>
                                    <option value="Custom">Custom Package</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="package_amount" class="form-label">Package Amount <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" name="package_amount" step="0.01" min="0" required>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="billing_frequency" class="form-label">Billing Frequency</label>
                                <select class="form-select" name="billing_frequency">
                                    <option value="monthly">Monthly</option>
                                    <option value="quarterly">Quarterly</option>
                                    <option value="annually">Annually</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="3" 
                                  placeholder="Describe the package details..."></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="start_date" class="form-label">Start Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="start_date" 
                                       value="<%= new Date().toISOString().split('T')[0] %>" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="end_date" class="form-label">End Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="end_date" required>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Create Package
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Payment Collection Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-cash me-2"></i>Collect Payment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="paymentForm" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="payment_amount" class="form-label">Payment Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" name="payment_amount" step="0.01" required>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="payment_method" class="form-label">Payment Method</label>
                        <select class="form-select" name="payment_method" required>
                            <option value="cash">Cash</option>
                            <option value="card">Credit/Debit Card</option>
                            <option value="bank_transfer">Bank Transfer</option>
                            <option value="check">Check</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="payment_notes" class="form-label">Notes</label>
                        <textarea class="form-control" name="payment_notes" rows="2" 
                                  placeholder="Payment notes (optional)"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Collect Payment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.avatar-sm {
    width: 32px;
    height: 32px;
    font-size: 14px;
    font-weight: 600;
}

.card {
    border-radius: 12px;
    transition: transform 0.2s ease-in-out;
}

.table thead th {
    border: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85em;
    letter-spacing: 0.5px;
}

.table tbody tr:hover {
    background-color: #f8f9fa !important;
}

.btn {
    border-radius: 8px;
    font-weight: 500;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Search functionality
    const searchInput = document.getElementById('searchPackages');
    if (searchInput) {
        searchInput.addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            const rows = document.querySelectorAll('#packagesTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    }

    // Initialize tooltips
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});

function collectPayment(packageId) {
    const form = document.getElementById('paymentForm');
    form.action = `/finance/packages/${packageId}/payment`;
    
    const modal = new bootstrap.Modal(document.getElementById('paymentModal'));
    modal.show();
}
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>