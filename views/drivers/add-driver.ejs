<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-plus-circle"></i> Add New Driver
                        </h5>
                    </div>
                    <div class="card-body">
                        
                        <form action="/drivers/add" method="POST" id="addDriverForm" novalidate>
                            <div class="row">
                                <!-- Basic Information -->
                                <div class="col-md-6">
                                    <h6 class="text-primary mb-3">Basic Information</h6>
                                    
                                    <div class="mb-3">
                                        <label for="full_name" class="form-label">Full Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="full_name" name="full_name" required 
                                               placeholder="Enter driver's full name" maxlength="100">
                                        <div class="invalid-feedback">Please provide a valid name.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="cnic" class="form-label">CNIC <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="cnic" name="cnic" required 
                                               placeholder="12345-1234567-1" pattern="[0-9]{5}-[0-9]{7}-[0-9]{1}"
                                               title="CNIC format: 12345-1234567-1">
                                        <div class="form-text">Format: 12345-1234567-1</div>
                                        <div class="invalid-feedback">Please provide a valid CNIC in format 12345-1234567-1.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="phone_primary" class="form-label">Phone Number <span class="text-danger">*</span></label>
                                        <input type="tel" class="form-control" id="phone_primary" name="phone_primary" required 
                                               placeholder="03XX-XXXXXXX" pattern="03[0-9]{2}-[0-9]{7}"
                                               title="Pakistani mobile number format: 03XX-XXXXXXX">
                                        <div class="form-text">Format: 03XX-XXXXXXX</div>
                                        <div class="invalid-feedback">Please provide a valid Pakistani phone number.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="phone_secondary" class="form-label">Secondary Phone (Optional)</label>
                                        <input type="tel" class="form-control" id="phone_secondary" name="phone_secondary" 
                                               placeholder="03XX-XXXXXXX" pattern="03[0-9]{2}-[0-9]{7}">
                                        <div class="form-text">Optional secondary contact number</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email (Optional)</label>
                                        <input type="email" class="form-control" id="email" name="email" 
                                               placeholder="driver@example.com">
                                    </div>

                                    <div class="mb-3">
                                        <label for="address" class="form-label">Address <span class="text-danger">*</span></label>
                                        <textarea class="form-control" id="address" name="address" rows="3" required 
                                                  placeholder="Enter complete address" maxlength="255"></textarea>
                                        <div class="invalid-feedback">Please provide an address.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="city" class="form-label">City <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="city" name="city" required 
                                               placeholder="Enter city" maxlength="100">
                                        <div class="invalid-feedback">Please provide a city.</div>
                                    </div>
                                </div>

                                <!-- License and Professional Information -->
                                <div class="col-md-6">
                                    <h6 class="text-primary mb-3">License Information</h6>
                                    
                                    <div class="mb-3">
                                        <label for="license_number" class="form-label">License Number <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="license_number" name="license_number" required 
                                               placeholder="Enter license number" maxlength="50">
                                        <div class="invalid-feedback">Please provide a license number.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="license_type" class="form-label">License Type <span class="text-danger">*</span></label>
                                        <select class="form-select" id="license_type" name="license_type" required>
                                            <option value="">Select license type</option>
                                            <option value="LTV">LTV (Light Transport Vehicle)</option>
                                            <option value="HTV">HTV (Heavy Transport Vehicle)</option>
                                            <option value="PSV">PSV (Public Service Vehicle)</option>
                                            <option value="Motorcycle">Motorcycle</option>
                                        </select>
                                        <div class="invalid-feedback">Please select a license type.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="license_expiry" class="form-label">License Expiry Date <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" id="license_expiry" name="license_expiry" required>
                                        <div class="invalid-feedback">Please provide license expiry date.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="hire_date" class="form-label">Date of Joining <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" id="hire_date" name="hire_date" required>
                                        <div class="invalid-feedback">Please provide joining date.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="experience_years" class="form-label">Experience (Years)</label>
                                        <input type="number" class="form-control" id="experience_years" name="experience_years" 
                                               min="0" max="50" placeholder="Years of driving experience">
                                    </div>

                                    <div class="mb-3">
                                        <label for="salary" class="form-label">Monthly Salary (PKR)</label>
                                        <input type="number" class="form-control" id="salary" name="salary" 
                                               min="0" placeholder="Monthly salary amount">
                                    </div>
                                </div>
                            </div>

                            <!-- Emergency Contact & Additional Info -->
                            <div class="row">
                                <div class="col-12">
                                    <hr>
                                    <h6 class="text-primary mb-3">Emergency Contact & Additional Information</h6>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="emergency_contact_name" class="form-label">Emergency Contact Name</label>
                                        <input type="text" class="form-control" id="emergency_contact_name" name="emergency_contact_name" 
                                               placeholder="Emergency contact person name" maxlength="100">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="emergency_contact_phone" class="form-label">Emergency Contact Phone</label>
                                        <input type="tel" class="form-control" id="emergency_contact_phone" name="emergency_contact_phone" 
                                               placeholder="03XX-XXXXXXX" pattern="03[0-9]{2}-[0-9]{7}">
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="mb-3">
                                        <label for="notes" class="form-label">Notes</label>
                                        <textarea class="form-control" id="notes" name="notes" rows="3" 
                                                  placeholder="Additional notes about the driver" maxlength="500"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Vehicle Assignment (Optional) -->
                            <div class="row">
                                <div class="col-12">
                                    <hr>
                                    <h6 class="text-primary mb-3">Vehicle Assignment (Optional)</h6>
                                    
                                    <div class="mb-3">
                                        <label for="assigned_vehicle_id" class="form-label">Assign Vehicle</label>
                                        <select class="form-select" id="assigned_vehicle_id" name="assigned_vehicle_id">
                                            <option value="">No vehicle assigned</option>
                                        </select>
                                        <div class="form-text">You can assign a vehicle now or later from the driver details page.</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="row">
                                <div class="col-12">
                                    <hr>
                                    <div class="d-flex justify-content-between">
                                        <a href="/drivers" class="btn btn-secondary">
                                            <i class="fas fa-arrow-left"></i> Back to Drivers
                                        </a>
                                        <div>
                                            <button type="reset" class="btn btn-outline-secondary me-2">
                                                <i class="fas fa-undo"></i> Reset
                                            </button>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="fas fa-save"></i> Add Driver
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Load available vehicles
    loadAvailableVehicles();
    
    // Set default hire date to today
    document.getElementById('hire_date').value = new Date().toISOString().split('T')[0];
    
    // Set minimum license expiry date to today
    document.getElementById('license_expiry').min = new Date().toISOString().split('T')[0];
    
    // Form validation
    const form = document.getElementById('addDriverForm');
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    });
    
    // Real-time CNIC formatting
    const cnicInput = document.getElementById('cnic');
    cnicInput.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length >= 5) {
            value = value.substring(0, 5) + '-' + value.substring(5);
        }
        if (value.length >= 13) {
            value = value.substring(0, 13) + '-' + value.substring(13, 14);
        }
        e.target.value = value;
    });
    
    // Real-time phone formatting for primary phone
    const phoneInput = document.getElementById('phone_primary');
    phoneInput.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length >= 4) {
            value = value.substring(0, 4) + '-' + value.substring(4, 11);
        }
        e.target.value = value;
    });
    
    // Real-time phone formatting for secondary phone
    const phoneSecondaryInput = document.getElementById('phone_secondary');
    if (phoneSecondaryInput) {
        phoneSecondaryInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 4) {
                value = value.substring(0, 4) + '-' + value.substring(4, 11);
            }
            e.target.value = value;
        });
    }
    
    // Real-time phone formatting for emergency contact
    const emergencyPhoneInput = document.getElementById('emergency_contact_phone');
    if (emergencyPhoneInput) {
        emergencyPhoneInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 4) {
                value = value.substring(0, 4) + '-' + value.substring(4, 11);
            }
            e.target.value = value;
        });
    }
});

async function loadAvailableVehicles() {
    try {
        const response = await fetch('/vehicles/api/available');
        const vehicles = await response.json();
        
        const select = document.getElementById('assigned_vehicle_id');
        // Clear existing options except the first one
        select.innerHTML = '<option value="">No vehicle assigned</option>';
        
        vehicles.forEach(vehicle => {
            const option = document.createElement('option');
            option.value = vehicle.id;
            option.textContent = `${vehicle.license_plate} - ${vehicle.vehicle_type} (${vehicle.capacity}L)`;
            select.appendChild(option);
        });
    } catch (error) {
        console.error('Error loading vehicles:', error);
    }
}
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>