<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <!-- Driver Information Card -->
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fas fa-id-card"></i> Driver Details - <%= driver.name %>
                            </h5>
                            <div>
                                <a href="/drivers/<%= driver.id %>/edit" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button class="btn btn-danger btn-sm" onclick="confirmDelete('<%= driver.id %>')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- Flash Messages -->
                        <%- include('../partials/flash') %>
                        
                        <div class="row">
                            <!-- Basic Information -->
                            <div class="col-md-6">
                                <h6 class="text-info mb-3">
                                    <i class="fas fa-user"></i> Basic Information
                                </h6>
                                
                                <table class="table table-borderless">
                                    <tr>
                                        <td><strong>Full Name:</strong></td>
                                        <td><%= driver.name %></td>
                                    </tr>
                                    <tr>
                                        <td><strong>CNIC:</strong></td>
                                        <td><%= driver.cnic %></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Phone:</strong></td>
                                        <td>
                                            <%= driver.phone %>
                                            <a href="tel:<%= driver.phone %>" class="btn btn-sm btn-outline-primary ms-2">
                                                <i class="fas fa-phone"></i> Call
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Address:</strong></td>
                                        <td><%= driver.address %></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Date of Joining:</strong></td>
                                        <td>
                                            <%= new Date(driver.date_of_joining).toLocaleDateString('en-GB') %>
                                            <small class="text-muted">
                                                (<%= Math.floor((new Date() - new Date(driver.date_of_joining)) / (1000 * 60 * 60 * 24)) %> days ago)
                                            </small>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- License Information -->
                            <div class="col-md-6">
                                <h6 class="text-info mb-3">
                                    <i class="fas fa-id-badge"></i> License Information
                                </h6>
                                
                                <table class="table table-borderless">
                                    <tr>
                                        <td><strong>License Number:</strong></td>
                                        <td><%= driver.license_number %></td>
                                    </tr>
                                    <tr>
                                        <td><strong>License Type:</strong></td>
                                        <td>
                                            <span class="badge bg-secondary"><%= driver.license_type %></span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Expiry Date:</strong></td>
                                        <td>
                                            <%= new Date(driver.license_expiry).toLocaleDateString('en-GB') %>
                                            <% 
                                            const daysUntilExpiry = Math.floor((new Date(driver.license_expiry) - new Date()) / (1000 * 60 * 60 * 24));
                                            %>
                                            <% if (daysUntilExpiry < 0) { %>
                                                <span class="badge bg-danger ms-2">Expired</span>
                                            <% } else if (daysUntilExpiry <= 30) { %>
                                                <span class="badge bg-warning ms-2">Expires in <%= daysUntilExpiry %> days</span>
                                            <% } else { %>
                                                <span class="badge bg-success ms-2">Valid</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td>
                                            <% if (daysUntilExpiry >= 0) { %>
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check"></i> Licensed
                                                </span>
                                            <% } else { %>
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-times"></i> License Expired
                                                </span>
                                            <% } %>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vehicle Assignment Card -->
                <div class="card mt-4">
                    <div class="card-header bg-secondary text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-truck"></i> Vehicle Assignment
                        </h6>
                    </div>
                    <div class="card-body">
                        <% if (driver.assigned_vehicle_id && driver.vehicle) { %>
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="d-flex align-items-center">
                                        <div class="vehicle-icon me-3">
                                            <i class="fas fa-truck fa-2x text-primary"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-1"><%= driver.vehicle.license_plate %></h6>
                                            <p class="mb-1 text-muted">
                                                <%= driver.vehicle.vehicle_type %> | Capacity: <%= driver.vehicle.capacity %>L
                                            </p>
                                            <small class="text-muted">
                                                Model: <%= driver.vehicle.model %> (<%= driver.vehicle.year %>)
                                            </small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 text-end">
                                    <a href="/vehicles/<%= driver.vehicle.id %>" class="btn btn-outline-primary btn-sm me-2">
                                        <i class="fas fa-eye"></i> View Vehicle
                                    </a>
                                    <button class="btn btn-outline-warning btn-sm" onclick="changeVehicle()">
                                        <i class="fas fa-exchange-alt"></i> Change
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" onclick="removeVehicle()">
                                        <i class="fas fa-unlink"></i> Remove
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Vehicle Status -->
                            <hr>
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <h6 class="text-muted">Insurance Status</h6>
                                        <% 
                                        const insuranceDays = Math.floor((new Date(driver.vehicle.insurance_expiry) - new Date()) / (1000 * 60 * 60 * 24));
                                        %>
                                        <% if (insuranceDays < 0) { %>
                                            <span class="badge bg-danger">Expired</span>
                                        <% } else if (insuranceDays <= 30) { %>
                                            <span class="badge bg-warning">Expires in <%= insuranceDays %> days</span>
                                        <% } else { %>
                                            <span class="badge bg-success">Valid</span>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <h6 class="text-muted">Maintenance Status</h6>
                                        <% if (driver.vehicle.maintenance_due && new Date(driver.vehicle.maintenance_due) <= new Date()) { %>
                                            <span class="badge bg-warning">Due</span>
                                        <% } else { %>
                                            <span class="badge bg-success">Up to date</span>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-center">
                                        <h6 class="text-muted">Vehicle Status</h6>
                                        <span class="badge bg-<%= driver.vehicle.status === 'active' ? 'success' : 'secondary' %>">
                                            <%= driver.vehicle.status === 'active' ? 'Active' : 'Inactive' %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="text-center py-4">
                                <i class="fas fa-truck fa-3x text-muted mb-3"></i>
                                <h6 class="text-muted">No Vehicle Assigned</h6>
                                <p class="text-muted">This driver is not currently assigned to any vehicle.</p>
                                <button class="btn btn-primary" onclick="assignVehicle()">
                                    <i class="fas fa-plus"></i> Assign Vehicle
                                </button>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Recent Orders/Activity -->
                <div class="card mt-4">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-history"></i> Recent Activity
                        </h6>
                    </div>
                    <div class="card-body">
                        <div id="recentActivity">
                            <div class="text-center">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2 text-muted">Loading recent activity...</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="card mt-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <a href="/drivers" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Drivers
                            </a>
                            <div>
                                <a href="/drivers/<%= driver.id %>/edit" class="btn btn-warning me-2">
                                    <i class="fas fa-edit"></i> Edit Driver
                                </a>
                                <button class="btn btn-danger" onclick="confirmDelete('<%= driver.id %>')">
                                    <i class="fas fa-trash"></i> Delete Driver
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

<!-- Vehicle Assignment Modal -->
<div class="modal fade" id="vehicleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="vehicleModalTitle">Assign Vehicle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="vehicleForm">
                    <div class="mb-3">
                        <label for="vehicleSelect" class="form-label">Select Vehicle</label>
                        <select class="form-select" id="vehicleSelect" required>
                            <option value="">Choose a vehicle...</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveVehicleAssignment()">Save Assignment</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this driver?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Warning:</strong> This action cannot be undone. The driver will be permanently removed from the system.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="deleteDriver()">Delete Driver</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    loadRecentActivity();
});

let driverIdToDelete = null;

function confirmDelete(driverId) {
    driverIdToDelete = driverId;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}

async function deleteDriver() {
    if (!driverIdToDelete) return;
    
    try {
        const response = await fetch(`/drivers/${driverIdToDelete}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        
        if (response.ok) {
            window.location.href = '/drivers';
        } else {
            const error = await response.json();
            alert('Error deleting driver: ' + error.message);
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error deleting driver');
    }
}

function assignVehicle() {
    document.getElementById('vehicleModalTitle').textContent = 'Assign Vehicle';
    loadAvailableVehicles();
    new bootstrap.Modal(document.getElementById('vehicleModal')).show();
}

function changeVehicle() {
    document.getElementById('vehicleModalTitle').textContent = 'Change Vehicle';
    loadAvailableVehicles();
    new bootstrap.Modal(document.getElementById('vehicleModal')).show();
}

async function removeVehicle() {
    if (confirm('Are you sure you want to remove the vehicle assignment?')) {
        try {
            const response = await fetch(`/drivers/<%= driver.id %>/remove-vehicle`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            
            if (response.ok) {
                location.reload();
            } else {
                const error = await response.json();
                alert('Error removing vehicle: ' + error.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error removing vehicle assignment');
        }
    }
}

async function loadAvailableVehicles() {
    try {
        const response = await fetch('/vehicles/api/available');
        const vehicles = await response.json();
        
        const select = document.getElementById('vehicleSelect');
        select.innerHTML = '<option value="">Choose a vehicle...</option>';
        
        vehicles.forEach(vehicle => {
            const option = document.createElement('option');
            option.value = vehicle.id;
            option.textContent = `${vehicle.license_plate} - ${vehicle.vehicle_type} (${vehicle.capacity}L)`;
            select.appendChild(option);
        });
    } catch (error) {
        console.error('Error loading vehicles:', error);
    }
}

async function saveVehicleAssignment() {
    const vehicleId = document.getElementById('vehicleSelect').value;
    if (!vehicleId) {
        alert('Please select a vehicle');
        return;
    }
    
    try {
        const response = await fetch(`/drivers/<%= driver.id %>/assign-vehicle`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ vehicleId })
        });
        
        if (response.ok) {
            location.reload();
        } else {
            const error = await response.json();
            alert('Error assigning vehicle: ' + error.message);
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Error assigning vehicle');
    }
}

async function loadRecentActivity() {
    try {
        const response = await fetch(`/drivers/<%= driver.id %>/activity`);
        const activity = await response.json();
        
        const container = document.getElementById('recentActivity');
        
        if (activity.length === 0) {
            container.innerHTML = `
                <div class="text-center py-4">
                    <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                    <h6 class="text-muted">No Recent Activity</h6>
                    <p class="text-muted">This driver has no recent delivery assignments.</p>
                </div>
            `;
            return;
        }
        
        let html = '<div class="table-responsive"><table class="table table-hover">';
        html += `
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Orders</th>
                    <th>Status</th>
                    <th>Vehicle</th>
                </tr>
            </thead>
            <tbody>
        `;
        
        activity.forEach(item => {
            html += `
                <tr>
                    <td>${new Date(item.date).toLocaleDateString('en-GB')}</td>
                    <td>${item.order_count} orders</td>
                    <td><span class="badge bg-${item.status === 'completed' ? 'success' : 'warning'}">${item.status}</span></td>
                    <td>${item.vehicle_info || 'No vehicle'}</td>
                </tr>
            `;
        });
        
        html += '</tbody></table></div>';
        container.innerHTML = html;
        
    } catch (error) {
        console.error('Error loading activity:', error);
        document.getElementById('recentActivity').innerHTML = `
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i>
                Unable to load recent activity.
            </div>
        `;
    }
}
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>