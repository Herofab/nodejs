<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="fas fa-edit"></i> Edit Driver - <%= driver.name %>
                        </h5>
                    </div>
                    <div class="card-body">
                        
                        <form action="/drivers/<%= driver.id %>" method="POST" id="editDriverForm" novalidate>
                            <input type="hidden" name="_method" value="PUT">
                            
                            <div class="row">
                                <!-- Basic Information -->
                                <div class="col-md-6">
                                    <h6 class="text-warning mb-3">Basic Information</h6>
                                    
                                    <div class="mb-3">
                                        <label for="name" class="form-label">Full Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="name" name="name" required 
                                               value="<%= driver.name %>" placeholder="Enter driver's full name" maxlength="100">
                                        <div class="invalid-feedback">Please provide a valid name.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="cnic" class="form-label">CNIC <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="cnic" name="cnic" required 
                                               value="<%= driver.cnic %>" placeholder="12345-1234567-1" 
                                               pattern="[0-9]{5}-[0-9]{7}-[0-9]{1}" title="CNIC format: 12345-1234567-1">
                                        <div class="form-text">Format: 12345-1234567-1</div>
                                        <div class="invalid-feedback">Please provide a valid CNIC in format 12345-1234567-1.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="phone" class="form-label">Phone Number <span class="text-danger">*</span></label>
                                        <input type="tel" class="form-control" id="phone" name="phone" required 
                                               value="<%= driver.phone %>" placeholder="03XX-XXXXXXX" 
                                               pattern="03[0-9]{2}-[0-9]{7}" title="Pakistani mobile number format: 03XX-XXXXXXX">
                                        <div class="form-text">Format: 03XX-XXXXXXX</div>
                                        <div class="invalid-feedback">Please provide a valid Pakistani phone number.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="address" class="form-label">Address <span class="text-danger">*</span></label>
                                        <textarea class="form-control" id="address" name="address" rows="3" required 
                                                  placeholder="Enter complete address" maxlength="255"><%= driver.address %></textarea>
                                        <div class="invalid-feedback">Please provide an address.</div>
                                    </div>
                                </div>

                                <!-- License Information -->
                                <div class="col-md-6">
                                    <h6 class="text-warning mb-3">License Information</h6>
                                    
                                    <div class="mb-3">
                                        <label for="license_number" class="form-label">License Number <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="license_number" name="license_number" required 
                                               value="<%= driver.license_number %>" placeholder="Enter license number" maxlength="50">
                                        <div class="invalid-feedback">Please provide a license number.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="license_type" class="form-label">License Type <span class="text-danger">*</span></label>
                                        <select class="form-select" id="license_type" name="license_type" required>
                                            <option value="">Select license type</option>
                                            <option value="LTV" <%= driver.license_type === 'LTV' ? 'selected' : '' %>>LTV (Light Transport Vehicle)</option>
                                            <option value="HTV" <%= driver.license_type === 'HTV' ? 'selected' : '' %>>HTV (Heavy Transport Vehicle)</option>
                                            <option value="PSV" <%= driver.license_type === 'PSV' ? 'selected' : '' %>>PSV (Public Service Vehicle)</option>
                                            <option value="Motorcycle" <%= driver.license_type === 'Motorcycle' ? 'selected' : '' %>>Motorcycle</option>
                                        </select>
                                        <div class="invalid-feedback">Please select a license type.</div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="license_expiry" class="form-label">License Expiry Date <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" id="license_expiry" name="license_expiry" required
                                               value="<%= driver.license_expiry ? driver.license_expiry.toISOString().split('T')[0] : '' %>">
                                        <div class="invalid-feedback">Please provide license expiry date.</div>
                                        <% if (driver.license_expiry && (new Date(driver.license_expiry) - new Date()) < 30 * 24 * 60 * 60 * 1000) { %>
                                            <div class="alert alert-warning mt-2" role="alert">
                                                <i class="fas fa-exclamation-triangle"></i> License expires soon!
                                            </div>
                                        <% } %>
                                    </div>

                                    <div class="mb-3">
                                        <label for="date_of_joining" class="form-label">Date of Joining <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" id="date_of_joining" name="date_of_joining" required
                                               value="<%= driver.date_of_joining ? driver.date_of_joining.toISOString().split('T')[0] : '' %>">
                                        <div class="invalid-feedback">Please provide joining date.</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Vehicle Assignment -->
                            <div class="row">
                                <div class="col-12">
                                    <hr>
                                    <h6 class="text-warning mb-3">Vehicle Assignment</h6>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="assigned_vehicle_id" class="form-label">Assign Vehicle</label>
                                                <select class="form-select" id="assigned_vehicle_id" name="assigned_vehicle_id">
                                                    <option value="">No vehicle assigned</option>
                                                </select>
                                                <div class="form-text">You can change vehicle assignment or remove it.</div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <% if (driver.assigned_vehicle_id && driver.vehicle) { %>
                                                <div class="alert alert-info">
                                                    <strong>Currently Assigned:</strong><br>
                                                    <i class="fas fa-truck"></i> <%= driver.vehicle.license_plate %> - <%= driver.vehicle.vehicle_type %>
                                                    <br><small>Capacity: <%= driver.vehicle.capacity %>L</small>
                                                </div>
                                            <% } else { %>
                                                <div class="alert alert-secondary">
                                                    <i class="fas fa-info-circle"></i> No vehicle currently assigned
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="row">
                                <div class="col-12">
                                    <hr>
                                    <div class="d-flex justify-content-between">
                                        <a href="/drivers/<%= driver.id %>" class="btn btn-secondary">
                                            <i class="fas fa-arrow-left"></i> Back to Details
                                        </a>
                                        <div>
                                            <a href="/drivers" class="btn btn-outline-secondary me-2">
                                                <i class="fas fa-list"></i> All Drivers
                                            </a>
                                            <button type="submit" class="btn btn-warning">
                                                <i class="fas fa-save"></i> Update Driver
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Load available vehicles
    loadAvailableVehicles();
    
    // Set minimum license expiry date to today
    document.getElementById('license_expiry').min = new Date().toISOString().split('T')[0];
    
    // Form validation
    const form = document.getElementById('editDriverForm');
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    });
    
    // Real-time CNIC formatting
    const cnicInput = document.getElementById('cnic');
    cnicInput.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length >= 5) {
            value = value.substring(0, 5) + '-' + value.substring(5);
        }
        if (value.length >= 13) {
            value = value.substring(0, 13) + '-' + value.substring(13, 14);
        }
        e.target.value = value;
    });
    
    // Real-time phone formatting
    const phoneInput = document.getElementById('phone');
    phoneInput.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length >= 4) {
            value = value.substring(0, 4) + '-' + value.substring(4, 11);
        }
        e.target.value = value;
    });
});

async function loadAvailableVehicles() {
    try {
        const response = await fetch('/vehicles/api/available');
        const vehicles = await response.json();
        
        const select = document.getElementById('assigned_vehicle_id');
        const currentVehicleId = '<%= driver.assigned_vehicle_id || "" %>';
        
        // Clear existing options except the first one
        select.innerHTML = '<option value="">No vehicle assigned</option>';
        
        // Add current vehicle first if assigned
        const currentVehicleData = {
            id: '<%= driver.assigned_vehicle_id || "" %>',
            license_plate: '<%= driver.vehicle ? driver.vehicle.license_plate : "" %>',
            vehicle_type: '<%= driver.vehicle ? driver.vehicle.vehicle_type : "" %>',
            capacity: '<%= driver.vehicle ? driver.vehicle.capacity : "" %>'
        };
        
        if (currentVehicleData.id) {
            const currentOption = document.createElement('option');
            currentOption.value = currentVehicleData.id;
            currentOption.textContent = `${currentVehicleData.license_plate} - ${currentVehicleData.vehicle_type} (${currentVehicleData.capacity}L) [Currently Assigned]`;
            currentOption.selected = true;
            select.appendChild(currentOption);
        }
        
        // Add available vehicles
        vehicles.forEach(vehicle => {
            // Skip if this is the currently assigned vehicle
            if (vehicle.id.toString() !== currentVehicleId) {
                const option = document.createElement('option');
                option.value = vehicle.id;
                option.textContent = `${vehicle.license_plate} - ${vehicle.vehicle_type} (${vehicle.capacity}L)`;
                select.appendChild(option);
            }
        });
    } catch (error) {
        console.error('Error loading vehicles:', error);
    }
}
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>