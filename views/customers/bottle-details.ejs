<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-person-circle me-2"></i><%= customer.full_name %> - Bottle Inventory</h2>
                <div class="btn-group">
                    <a href="/customer-bottles/bottle-inventory" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Inventory
                    </a>
                    <a href="/customers/<%= customer.id %>" class="btn btn-outline-primary">
                        <i class="bi bi-person me-1"></i>Customer Details
                    </a>
                </div>
            </div>

            <!-- Customer Summary -->
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Customer Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Name:</strong> <%= customer.full_name %></p>
                                    <p><strong>Phone:</strong> <%= customer.phone_primary || 'N/A' %></p>
                                    <p><strong>Email:</strong> <%= customer.email || 'N/A' %></p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Address:</strong><br>
                                    <%= customer.address_line1 || 'No Address' %><br>
                                    <%= customer.city || '' %> <%= customer.state || '' %> <%= customer.zip_code || '' %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-primary text-white">
                        <div class="card-body text-center">
                            <h3 class="card-title"><%= currentBottles.length %></h3>
                            <p class="card-text">Current Bottles</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Current Bottles -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Current Bottles at Customer</h5>
                    <% if (currentBottles.length > 0) { %>
                    <span class="badge bg-success">Active: <%= currentBottles.length %></span>
                    <% } %>
                </div>
                <div class="card-body">
                    <% if (currentBottles.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Bottle Code</th>
                                    <th>Bottle Type</th>
                                    <th>Delivered Date</th>
                                    <th>Delivered By</th>
                                    <th>Days at Customer</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% currentBottles.forEach(bottle => { %>
                                <tr>
                                    <td>
                                        <span class="badge bg-dark fs-6"><%= bottle.bottle_code %></span>
                                    </td>
                                    <td><%= bottle.bottle_type %></td>
                                    <td>
                                        <%= new Date(bottle.delivered_at).toLocaleDateString() %>
                                        <small class="text-muted d-block">
                                            <%= new Date(bottle.delivered_at).toLocaleTimeString() %>
                                        </small>
                                    </td>
                                    <td>
                                        <% if (bottle.delivered_by_name) { %>
                                        <%= bottle.delivered_by_name %>
                                        <% } else { %>
                                        <%= bottle.delivered_by_email || 'Unknown' %>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% 
                                        const deliveredDate = new Date(bottle.delivered_at);
                                        const today = new Date();
                                        const diffTime = Math.abs(today - deliveredDate);
                                        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                        %>
                                        <%= diffDays %> days
                                        <% if (diffDays > 30) { %>
                                        <span class="badge bg-warning ms-1">Long Term</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge bg-success"><%= bottle.status %></span>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        This customer currently has no bottles.
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Delivery History -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Bottle Delivery History</h5>
                </div>
                <div class="card-body">
                    <% if (deliveryHistory.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Bottle Code</th>
                                    <th>Type</th>
                                    <th>Order #</th>
                                    <th>Status Change</th>
                                    <th>Delivered By</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% deliveryHistory.forEach(history => { %>
                                <tr>
                                    <td>
                                        <%= new Date(history.delivered_at).toLocaleDateString() %>
                                        <small class="text-muted d-block">
                                            <%= new Date(history.delivered_at).toLocaleTimeString() %>
                                        </small>
                                    </td>
                                    <td>
                                        <code><%= history.bottle_code %></code>
                                    </td>
                                    <td><%= history.bottle_type %></td>
                                    <td>
                                        <% if (history.order_number) { %>
                                        <a href="/orders/<%= history.order_id %>" class="text-decoration-none">
                                            <%= history.order_number %>
                                        </a>
                                        <% } else { %>
                                        <span class="text-muted">-</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary"><%= history.status_from %></span>
                                        <i class="bi bi-arrow-right mx-1"></i>
                                        <span class="badge bg-success"><%= history.status_to %></span>
                                    </td>
                                    <td>
                                        <small><%= history.delivered_by_email || 'System' %></small>
                                    </td>
                                    <td>
                                        <small><%= history.notes || '-' %></small>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        No delivery history found for this customer.
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.badge {
    font-size: 0.8em;
}

code {
    background-color: #f8f9fa;
    padding: 2px 4px;
    border-radius: 3px;
}

.table td {
    vertical-align: middle;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>