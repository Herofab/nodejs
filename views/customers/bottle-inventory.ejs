<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="text-primary mb-1">
                        <i class="bi bi-bottle me-2"></i>Customer Bottle Inventory
                    </h2>
                    <p class="text-muted">Track which bottles are currently with customers</p>
                </div>
                <div class="btn-group">
                    <a href="/customers" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Customers
                    </a>
                    <button class="btn btn-primary" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i>Print Report
                    </button>
                </div>
            </div>

            <!-- Summary Statistics -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm bg-gradient">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                            <i class="bi bi-people-fill fs-1 mb-2"></i>
                            <h3 class="card-title mb-1"><%= stats.customers_with_bottles %></h3>
                            <p class="card-text opacity-75">Customers with Bottles</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm bg-gradient">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
                            <i class="bi bi-bottle-fill fs-1 mb-2"></i>
                            <h3 class="card-title mb-1"><%= stats.total_bottles_at_customers %></h3>
                            <p class="card-text opacity-75">Total Bottles at Customers</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm bg-gradient">
                        <div class="card-body text-center" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white;">
                            <i class="bi bi-collection-fill fs-1 mb-2"></i>
                            <h3 class="card-title mb-1"><%= stats.bottle_types_in_circulation %></h3>
                            <p class="card-text opacity-75">Bottle Types in Circulation</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Customer Bottle Table -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-0">
                    <h5 class="mb-0 text-dark">
                        <i class="bi bi-table me-2"></i>Customer Bottle Inventory
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="bottleInventoryTable">
                            <thead class="table-dark">
                                <tr>
                                    <th><i class="bi bi-person me-1"></i>Customer</th>
                                    <th><i class="bi bi-telephone me-1"></i>Contact</th>
                                    <th><i class="bi bi-geo-alt me-1"></i>Address</th>
                                    <th><i class="bi bi-123 me-1"></i>Bottles Count</th>
                                    <th><i class="bi bi-bottle me-1"></i>Bottle Details</th>
                                    <th><i class="bi bi-gear me-1"></i>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% customers.forEach(customer => { %>
                                <tr class="<%= customer.bottles_count > 0 ? '' : 'table-light' %>">
                                    <td class="p-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-3">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <div>
                                                <strong class="text-dark"><%= customer.customer_name %></strong>
                                                <% if (customer.bottles_count > 0) { %>
                                                <span class="badge bg-success ms-2">Has Bottles</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <i class="bi bi-telephone me-1"></i><%= customer.phone_primary || 'N/A' %>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <%= customer.address_line1 || 'No Address' %><br>
                                            <%= customer.city || '' %>
                                        </small>
                                    </td>
                                    <td class="p-3">
                                        <% if (customer.bottles_count > 0) { %>
                                        <h5 class="text-primary mb-0">
                                            <i class="bi bi-bottle-fill me-1"></i><%= customer.bottles_count %>
                                        </h5>
                                        <small class="text-muted">bottles</small>
                                        <% } else { %>
                                        <span class="text-muted">
                                            <i class="bi bi-dash-circle me-1"></i>No bottles
                                        </span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (customer.bottles && customer.bottles.length > 0) { %>
                                        <div class="bottle-codes">
                                            <% customer.bottles.slice(0, 3).forEach(bottle => { %>
                                            <span class="badge bg-secondary me-1 mb-1" title="<%= bottle.bottle_type %> - Delivered: <%= new Date(bottle.delivered_at).toLocaleDateString() %>">
                                                <%= bottle.bottle_code %>
                                            </span>
                                            <% }); %>
                                            <% if (customer.bottles.length > 3) { %>
                                            <span class="text-muted">+<%= customer.bottles.length - 3 %> more</span>
                                            <% } %>
                                        </div>
                                        <% } else { %>
                                        <span class="text-muted">-</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/customers/<%= customer.customer_id %>" class="btn btn-outline-primary" title="View Customer">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <% if (customer.bottles_count > 0) { %>
                                            <a href="/customer-bottles/<%= customer.customer_id %>/bottles" class="btn btn-outline-success" title="View Bottle Details">
                                                <i class="bi bi-bottle"></i>
                                            </a>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
@media print {
    .btn-group, .card-header, .d-flex { display: none !important; }
    .card { border: none !important; box-shadow: none !important; }
}

.bottle-codes {
    max-width: 200px;
}

.table td {
    vertical-align: middle;
}

.badge {
    font-size: 0.75em;
}

.avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
}

.card {
    border-radius: 12px;
    transition: transform 0.2s ease-in-out;
}

.card:hover {
    transform: translateY(-2px);
}

.table thead th {
    border: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85em;
    letter-spacing: 0.5px;
}

.table tbody tr {
    border: none;
}

.table tbody tr:hover {
    background-color: #f8f9fa !important;
}

.search-box {
    border-radius: 25px;
    border: 2px solid #e9ecef;
    padding: 10px 20px;
    transition: all 0.3s ease;
}

.search-box:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
}

.bg-gradient {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.btn {
    border-radius: 8px;
    font-weight: 500;
}

.btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.15);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Add search functionality
    const searchInput = document.createElement('input');
    searchInput.type = 'text';
    searchInput.className = 'form-control search-box mb-3';
    searchInput.placeholder = '🔍 Search customers...';
    
    const tableContainer = document.querySelector('.table-responsive');
    tableContainer.parentNode.insertBefore(searchInput, tableContainer);
    
    searchInput.addEventListener('keyup', function() {
        const filter = this.value.toLowerCase();
        const rows = document.querySelectorAll('#bottleInventoryTable tbody tr');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(filter) ? '' : 'none';
        });
    });
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>