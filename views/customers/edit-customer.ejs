<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="container mt-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item"><a href="/customers">Customers</a></li>
                        <li class="breadcrumb-item"><a href="/customers/<%= customer.id %>"><%= customer.full_name %></a></li>
                        <li class="breadcrumb-item active">Edit</li>
                    </ol>
                </nav>
                <h1><i class="fas fa-user-edit text-warning"></i> Edit Customer</h1>
            </div>
        </div>

        <!-- Edit Customer Form -->
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-user-edit"></i> Customer Information</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="/customers/<%= customer.id %>/edit" id="editCustomerForm">
                            <!-- Personal Information -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Personal Information</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="full_name" class="form-label">Full Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="full_name" name="full_name" 
                                           value="<%= customer.full_name %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="cnic" class="form-label">CNIC <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="cnic" name="cnic" 
                                           pattern="[0-9]{5}-[0-9]{7}-[0-9]{1}" 
                                           placeholder="12345-1234567-1" value="<%= customer.cnic %>" required>
                                    <small class="text-muted">Format: 12345-1234567-1</small>
                                    <div id="cnic-feedback" class="invalid-feedback"></div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="phone_primary" class="form-label">Primary Phone <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="phone_primary" name="phone_primary" 
                                           placeholder="03001234567" value="<%= customer.phone_primary %>" required>
                                    <div id="phone-feedback" class="invalid-feedback"></div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="phone_secondary" class="form-label">Secondary Phone</label>
                                    <input type="text" class="form-control" id="phone_secondary" name="phone_secondary" 
                                           placeholder="03001234567" value="<%= customer.phone_secondary || '' %>">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">Email</label>
                                    <input type="email" class="form-control" id="email" name="email" 
                                           placeholder="customer@example.com" value="<%= customer.email || '' %>">
                                    <div id="email-feedback" class="invalid-feedback"></div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="customer_type" class="form-label">Customer Type</label>
                                    <select class="form-select" id="customer_type" name="customer_type">
                                        <option value="residential" <%= customer.customer_type === 'residential' ? 'selected' : '' %>>Residential</option>
                                        <option value="commercial" <%= customer.customer_type === 'commercial' ? 'selected' : '' %>>Commercial</option>
                                        <option value="industrial" <%= customer.customer_type === 'industrial' ? 'selected' : '' %>>Industrial</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Address Information -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Address Information</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="address_line1" class="form-label">Address Line 1 <span class="text-danger">*</span></label>
                                    <textarea class="form-control" id="address_line1" name="address_line1" 
                                              rows="2" placeholder="House/Building, Street" required><%= customer.address_line1 %></textarea>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="address_line2" class="form-label">Address Line 2</label>
                                    <textarea class="form-control" id="address_line2" name="address_line2" 
                                              rows="2" placeholder="Additional address details"><%= customer.address_line2 || '' %></textarea>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="city" class="form-label">City <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="city" name="city" 
                                           placeholder="Karachi" value="<%= customer.city %>" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="area" class="form-label">Area</label>
                                    <input type="text" class="form-control" id="area" name="area" 
                                           placeholder="DHA, Gulshan" value="<%= customer.area || '' %>">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="postal_code" class="form-label">Postal Code</label>
                                    <input type="text" class="form-control" id="postal_code" name="postal_code" 
                                           placeholder="75500" value="<%= customer.postal_code || '' %>">
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label for="landmark" class="form-label">Landmark</label>
                                    <input type="text" class="form-control" id="landmark" name="landmark" 
                                           placeholder="Near Main Market" value="<%= customer.landmark || '' %>">
                                </div>
                            </div>

                            <!-- Account Settings -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Account Settings</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="status" class="form-label">Status</label>
                                    <select class="form-select" id="status" name="status">
                                        <option value="active" <%= customer.status === 'active' ? 'selected' : '' %>>Active</option>
                                        <option value="suspended" <%= customer.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
                                        <option value="inactive" <%= customer.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="credit_limit" class="form-label">Credit Limit (Rs.)</label>
                                    <input type="number" class="form-control" id="credit_limit" name="credit_limit" 
                                           min="0" step="0.01" value="<%= customer.credit_limit || 0 %>">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="current_balance" class="form-label">Current Balance (Rs.)</label>
                                    <input type="number" class="form-control" id="current_balance" name="current_balance" 
                                           step="0.01" value="<%= customer.current_balance || 0 %>">
                                </div>
                            </div>

                            <!-- Notes -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Additional Information</h6>
                                </div>
                                <div class="col-12 mb-3">
                                    <label for="notes" class="form-label">Notes</label>
                                    <textarea class="form-control" id="notes" name="notes" rows="3" 
                                              placeholder="Any additional notes about the customer..."><%= customer.notes || '' %></textarea>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Update Customer
                                </button>
                                <a href="/customers/<%= customer.id %>" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Customer Info Sidebar -->
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h6><i class="fas fa-info-circle"></i> Customer Info</h6>
                    </div>
                    <div class="card-body">
                        <p><strong>Customer Code:</strong> <%= customer.customer_code %></p>
                        <p><strong>Registration Date:</strong> <%= new Date(customer.created_at).toLocaleDateString() %></p>
                        <p><strong>Current Status:</strong> 
                            <span class="badge bg-<%= customer.status === 'active' ? 'success' : customer.status === 'suspended' ? 'warning' : 'danger' %>">
                                <%= (customer.status || 'active').toUpperCase() %>
                            </span>
                        </p>
                        <hr>
                        <div class="d-grid gap-2">
                            <a href="/customers/<%= customer.id %>" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye"></i> View Details
                            </a>
                            <a href="/orders/add?customer=<%= customer.id %>" class="btn btn-outline-success btn-sm">
                                <i class="fas fa-plus-circle"></i> Create Order
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Warning Notice -->
                <div class="card mt-3">
                    <div class="card-body">
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Note:</strong> Changes to customer information will affect all existing and future orders.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Phone number formatting
            ['phone_primary', 'phone_secondary'].forEach(id => {
                const phoneInput = document.getElementById(id);
                if (phoneInput) {
                    phoneInput.addEventListener('input', function(e) {
                        let value = e.target.value.replace(/\D/g, '');
                        if (value.length > 11) {
                            value = value.substring(0, 11);
                        }
                        e.target.value = value;
                    });
                }
            });

            // CNIC formatting
            const cnicInput = document.getElementById('cnic');
            if (cnicInput) {
                cnicInput.addEventListener('input', function(e) {
                    let value = e.target.value.replace(/\D/g, '');
                    if (value.length > 5) {
                        value = value.substring(0, 5) + '-' + value.substring(5);
                    }
                    if (value.length > 13) {
                        value = value.substring(0, 13) + '-' + value.substring(13);
                    }
                    if (value.length > 15) {
                        value = value.substring(0, 15);
                    }
                    e.target.value = value;
                });
            }

            // Real-time duplicate checking
            let duplicateTimeout;
            const checkDuplicates = async () => {
                const cnic = document.getElementById('cnic').value;
                const phone = document.getElementById('phone_primary').value;
                const email = document.getElementById('email').value;

                if (!cnic && !phone && !email) return;

                try {
                    const response = await fetch('/customers/api/check-duplicate', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            cnic: cnic || null,
                            phone_primary: phone || null,
                            email: email || null,
                            excludeId: '<%= customer.id %>'
                        })
                    });

                    const duplicates = await response.json();

                    // Update CNIC feedback
                    const cnicInput = document.getElementById('cnic');
                    const cnicFeedback = document.getElementById('cnic-feedback');
                    if (duplicates.cnic) {
                        cnicInput.classList.add('is-invalid');
                        cnicFeedback.textContent = 'A customer with this CNIC already exists';
                        cnicFeedback.style.display = 'block';
                    } else {
                        cnicInput.classList.remove('is-invalid');
                        cnicFeedback.style.display = 'none';
                    }

                    // Update phone feedback
                    const phoneInput = document.getElementById('phone_primary');
                    const phoneFeedback = document.getElementById('phone-feedback');
                    if (duplicates.phone_primary) {
                        phoneInput.classList.add('is-invalid');
                        phoneFeedback.textContent = 'A customer with this phone number already exists';
                        phoneFeedback.style.display = 'block';
                    } else {
                        phoneInput.classList.remove('is-invalid');
                        phoneFeedback.style.display = 'none';
                    }

                    // Update email feedback
                    const emailInput = document.getElementById('email');
                    const emailFeedback = document.getElementById('email-feedback');
                    if (duplicates.email) {
                        emailInput.classList.add('is-invalid');
                        emailFeedback.textContent = 'A customer with this email already exists';
                        emailFeedback.style.display = 'block';
                    } else {
                        emailInput.classList.remove('is-invalid');
                        emailFeedback.style.display = 'none';
                    }

                } catch (error) {
                    console.error('Error checking duplicates:', error);
                }
            };

            // Add event listeners for real-time checking
            ['cnic', 'phone_primary', 'email'].forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (field) {
                    field.addEventListener('input', () => {
                        clearTimeout(duplicateTimeout);
                        duplicateTimeout = setTimeout(checkDuplicates, 500);
                    });
                }
            });

            // Form validation
            const form = document.getElementById('editCustomerForm');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const cnic = document.getElementById('cnic').value;
                    const cnicPattern = /^[0-9]{5}-[0-9]{7}-[0-9]{1}$/;
                    
                    // Check for validation errors
                    const hasInvalidFields = form.querySelector('.is-invalid');
                    if (hasInvalidFields) {
                        e.preventDefault();
                        alert('Please fix the validation errors before submitting');
                        return false;
                    }
                    
                    if (!cnicPattern.test(cnic)) {
                        e.preventDefault();
                        alert('Please enter a valid CNIC in format: 12345-1234567-1');
                        document.getElementById('cnic').focus();
                        return false;
                    }

                    const primaryPhone = document.getElementById('phone_primary').value;
                    if (primaryPhone.length < 10) {
                        e.preventDefault();
                        alert('Please enter a valid phone number (at least 10 digits)');
                        document.getElementById('phone_primary').focus();
                        return false;
                    }
                });
            }
        });
    </script>
</body>
</html>