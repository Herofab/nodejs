<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <style>
        #qr-reader {
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
        }
        
        .bottle-card {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
        }
        
        .status-badge {
            font-size: 0.875rem;
            padding: 0.375rem 0.75rem;
        }
        
        .status-at_plant { background-color: #e3f2fd; color: #1976d2; }
        .status-at_vehicle { background-color: #fff3e0; color: #f57c00; }
        .status-at_customer { background-color: #e8f5e8; color: #388e3c; }
        
        .movement-timeline {
            border-left: 2px solid #dee2e6;
            padding-left: 1rem;
        }
        
        .movement-item {
            position: relative;
            padding-bottom: 1rem;
        }
        
        .movement-item::before {
            content: '';
            position: absolute;
            left: -6px;
            top: 5px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: #007bff;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <h1><i class="fas fa-qrcode text-primary"></i> QR Code Scanner</h1>
                <p class="text-muted">Scan bottle QR codes to track location and status</p>
            </div>
        </div>

        <div class="row">
            <!-- QR Scanner Column -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-camera"></i> Camera Scanner</h5>
                    </div>
                    <div class="card-body">
                        <div id="qr-reader"></div>
                        <div class="mt-3">
                            <button id="start-scan" class="btn btn-success">
                                <i class="fas fa-play"></i> Start Scanner
                            </button>
                            <button id="stop-scan" class="btn btn-danger" style="display: none;">
                                <i class="fas fa-stop"></i> Stop Scanner
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Manual Input -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h5><i class="fas fa-keyboard"></i> Manual Input</h5>
                    </div>
                    <div class="card-body">
                        <form id="manual-scan-form">
                            <div class="input-group">
                                <input type="text" class="form-control" id="manual-qr-input" 
                                       placeholder="Enter QR code data or bottle code">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-search"></i> Search
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Results Column -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-info-circle"></i> Bottle Information</h5>
                    </div>
                    <div class="card-body" id="bottle-info">
                        <div class="text-center text-muted">
                            <i class="fas fa-qrcode fa-3x mb-3"></i>
                            <p>Scan a QR code to view bottle details</p>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card mt-3" id="quick-actions" style="display: none;">
                    <div class="card-header">
                        <h5><i class="fas fa-lightning-bolt"></i> Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="btn-group-vertical w-100" role="group">
                            <button type="button" class="btn btn-outline-success" onclick="updateBottleStatus('delivered')">
                                <i class="fas fa-check"></i> Mark as Delivered
                            </button>
                            <button type="button" class="btn btn-outline-warning" onclick="updateBottleStatus('returned')">
                                <i class="fas fa-undo"></i> Mark as Returned
                            </button>
                            <button type="button" class="btn btn-outline-info" onclick="viewFullHistory()">
                                <i class="fas fa-history"></i> View Full History
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let html5QrcodeScanner = null;
        let currentBottle = null;

        // Initialize QR Scanner
        function initScanner() {
            html5QrcodeScanner = new Html5QrcodeScanner(
                "qr-reader",
                { 
                    fps: 10, 
                    qrbox: { width: 250, height: 250 },
                    aspectRatio: 1.0,
                    supportedScanTypes: [Html5QrcodeScanType.SCAN_TYPE_CAMERA]
                },
                false
            );
        }

        // Start scanning
        document.getElementById('start-scan').addEventListener('click', function() {
            if (!html5QrcodeScanner) {
                initScanner();
            }
            
            html5QrcodeScanner.render(onScanSuccess, onScanFailure);
            document.getElementById('start-scan').style.display = 'none';
            document.getElementById('stop-scan').style.display = 'inline-block';
        });

        // Stop scanning
        document.getElementById('stop-scan').addEventListener('click', function() {
            if (html5QrcodeScanner) {
                html5QrcodeScanner.clear();
            }
            document.getElementById('start-scan').style.display = 'inline-block';
            document.getElementById('stop-scan').style.display = 'none';
        });

        // Handle successful scan
        function onScanSuccess(decodedText, decodedResult) {
            console.log(`Code matched = ${decodedText}`, decodedResult);
            processQRCode(decodedText);
        }

        // Handle scan failure
        function onScanFailure(error) {
            // console.warn(`Code scan error = ${error}`);
        }

        // Process QR code data
        function processQRCode(qrData) {
            fetch('/bottle-tracking/scan', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ qr_data: qrData })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    displayBottleInfo(data.bottle, data.history);
                    currentBottle = data.bottle;
                } else {
                    alert('Error: ' + data.error);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to process QR code');
            });
        }

        // Display bottle information
        function displayBottleInfo(bottle, history) {
            const bottleInfo = document.getElementById('bottle-info');
            const quickActions = document.getElementById('quick-actions');
            
            bottleInfo.innerHTML = `
                <div class="bottle-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h6 class="mb-1">Bottle Code: <strong>${bottle.bottle_code}</strong></h6>
                            <p class="text-muted mb-1">Type: ${bottle.bottle_type}</p>
                        </div>
                        <span class="badge status-${bottle.status} status-badge">
                            ${bottle.status.replace('_', ' ').toUpperCase()}
                        </span>
                    </div>
                    
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted">Current Location:</small>
                            <p class="mb-1">${bottle.current_location || 'Unknown'}</p>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">Manufacturing Date:</small>
                            <p class="mb-1">${bottle.manufacturing_date || 'N/A'}</p>
                        </div>
                    </div>
                    
                    ${bottle.order_number ? `
                        <div class="mt-2 p-2 bg-light rounded">
                            <small class="text-muted">Currently assigned to:</small>
                            <p class="mb-0"><strong>Order: ${bottle.order_number}</strong></p>
                            ${bottle.customer_name ? `<p class="mb-0">Customer: ${bottle.customer_name}</p>` : ''}
                        </div>
                    ` : ''}
                </div>
                
                ${history && history.length > 0 ? `
                    <div class="mt-3">
                        <h6>Recent Movement History</h6>
                        <div class="movement-timeline">
                            ${history.slice(0, 3).map(movement => `
                                <div class="movement-item">
                                    <small class="text-muted">${new Date(movement.movement_date).toLocaleString()}</small>
                                    <p class="mb-1"><strong>${movement.movement_type.toUpperCase()}</strong></p>
                                    <p class="mb-1">${movement.from_status} → ${movement.to_status}</p>
                                    ${movement.notes ? `<small class="text-muted">${movement.notes}</small>` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                ` : ''}
            `;
            
            quickActions.style.display = 'block';
        }

        // Manual scan form
        document.getElementById('manual-scan-form').addEventListener('submit', function(e) {
            e.preventDefault();
            const qrData = document.getElementById('manual-qr-input').value.trim();
            if (qrData) {
                processQRCode(qrData);
            }
        });

        // Update bottle status
        function updateBottleStatus(newStatus) {
            if (!currentBottle) {
                alert('No bottle selected');
                return;
            }
            
            // Implementation for status update
            alert(`Status update for bottle ${currentBottle.bottle_code}: ${newStatus}`);
        }

        // View full history
        function viewFullHistory() {
            if (!currentBottle) {
                alert('No bottle selected');
                return;
            }
            
            window.open(`/bottles/${currentBottle.id}/detail`, '_blank');
        }
    </script>
</body>
</html>