<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="fas fa-edit"></i> Edit Bottle</h1>
                    <div>
                        <a href="/bottles/<%= bottle.id %>" class="btn btn-info">
                            <i class="fas fa-eye"></i> View Details
                        </a>
                        <a href="/bottles" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fas fa-wine-bottle"></i> 
                            Edit Bottle: <strong class="text-primary"><%= bottle.bottleCode %></strong>
                        </h5>
                    </div>
                    <div class="card-body">
                        <form action="/bottles/<%= bottle.id %>/edit" method="POST" data-validate>
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">
                                        <i class="fas fa-barcode"></i> Bottle Code
                                    </label>
                                    <input type="text" class="form-control" value="<%= bottle.bottleCode %>" readonly>
                                    <div class="form-text">Bottle code cannot be changed</div>
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label for="bottleType" class="form-label">
                                        <i class="fas fa-wine-bottle"></i> Bottle Type *
                                    </label>
                                    <select class="form-select" id="bottleType" name="bottleType" required>
                                        <option value="0.5L" <%= (formData.bottleType || bottle.bottleType) === '0.5L' ? 'selected' : '' %>>0.5 Liter</option>
                                        <option value="1L" <%= (formData.bottleType || bottle.bottleType) === '1L' ? 'selected' : '' %>>1 Liter</option>
                                        <option value="5L" <%= (formData.bottleType || bottle.bottleType) === '5L' ? 'selected' : '' %>>5 Liter</option>
                                        <option value="20L" <%= (formData.bottleType || bottle.bottleType) === '20L' ? 'selected' : '' %>>20 Liter</option>
                                    </select>
                                    <div class="form-text">Changing type will regenerate the QR code</div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="status" class="form-label">
                                        <i class="fas fa-map-marker-alt"></i> Status *
                                    </label>
                                    <select class="form-select" id="status" name="status" required>
                                        <option value="AtPlant" <%= (formData.status || bottle.status) === 'AtPlant' ? 'selected' : '' %>>At Plant</option>
                                        <option value="AtCustomer" <%= (formData.status || bottle.status) === 'AtCustomer' ? 'selected' : '' %>>At Customer</option>
                                        <option value="AtVehicle" <%= (formData.status || bottle.status) === 'AtVehicle' ? 'selected' : '' %>>At Vehicle</option>
                                    </select>
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label for="batchNumber" class="form-label">
                                        <i class="fas fa-barcode"></i> Batch Number
                                    </label>
                                    <input type="text" class="form-control" id="batchNumber" name="batchNumber" 
                                           maxlength="50" value="<%= formData.batchNumber || bottle.batchNumber || '' %>">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="expiryDate" class="form-label">
                                        <i class="fas fa-calendar"></i> Expiry Date
                                    </label>
                                    <input type="date" class="form-control" id="expiryDate" name="expiryDate" 
                                           value="<%= formData.expiryDate || bottle.expiryDate %>">
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">
                                        <i class="fas fa-calendar-plus"></i> Manufacturing Date
                                    </label>
                                    <input type="text" class="form-control" 
                                           value="<%= new Date(bottle.manufacturingDate).toLocaleDateString() %>" readonly>
                                    <div class="form-text">Manufacturing date cannot be changed</div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="description" class="form-label">
                                    <i class="fas fa-file-text"></i> Description
                                </label>
                                <textarea class="form-control" id="description" name="description" rows="3" 
                                          maxlength="500" placeholder="Optional description or notes about this bottle"><%= formData.description || bottle.description || '' %></textarea>
                                <div class="form-text">
                                    <span id="charCount">0</span>/500 characters
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <div class="alert alert-warning">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        <strong>Important Changes:</strong>
                                        <ul class="mb-0 mt-2">
                                            <li>Changing the bottle type will regenerate the QR code</li>
                                            <li>Status changes will be logged in the bottle history</li>
                                            <li>All changes will update the "Last Modified" timestamp</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a href="/bottles/<%= bottle.id %>" class="btn btn-secondary me-md-2">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Update Bottle
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Current Information Sidebar -->
            <div class="col-lg-4">
                <!-- Current Bottle Info -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-info-circle"></i> Current Information</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless table-sm">
                            <tr>
                                <td class="fw-bold text-muted">Code:</td>
                                <td><%= bottle.bottleCode %></td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Type:</td>
                                <td><span class="badge bg-info"><%= bottle.bottleType %></span></td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Status:</td>
                                <td>
                                    <span class="badge bg-<%= bottle.status === 'AtPlant' ? 'success' : bottle.status === 'AtCustomer' ? 'warning' : 'info' %>">
                                        <%= bottle.status.replace('At', 'At ') %>
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Created:</td>
                                <td><%= new Date(bottle.createdAt).toLocaleDateString() %></td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Updated:</td>
                                <td><%= new Date(bottle.updatedAt).toLocaleDateString() %></td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Expires:</td>
                                <td>
                                    <span class="<%= bottle.isExpired ? 'text-danger fw-bold' : bottle.isExpiringSoon ? 'text-warning fw-bold' : '' %>">
                                        <%= new Date(bottle.expiryDate).toLocaleDateString() %>
                                    </span>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Current QR Code -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-qrcode"></i> Current QR Code</h5>
                    </div>
                    <div class="card-body text-center">
                        <img src="<%= bottle.qrCodeData %>" alt="Current QR Code" 
                             class="img-fluid mb-3" style="max-width: 200px;" id="currentQR">
                        <div class="small text-muted">
                            This QR code will be updated if you change the bottle type
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-bolt"></i> Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-info btn-sm" onclick="resetForm()">
                                <i class="fas fa-undo"></i> Reset Form
                            </button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="previewChanges()">
                                <i class="fas fa-eye"></i> Preview Changes
                            </button>
                            <a href="/bottles/<%= bottle.id %>" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-arrow-left"></i> View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Preview Changes Modal -->
    <div class="modal fade" id="previewModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Preview Changes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Field</th>
                                    <th>Current Value</th>
                                    <th>New Value</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="previewTableBody">
                                <!-- Changes will be populated here -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="submitForm()">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form[data-validate]');
            const descriptionInput = document.getElementById('description');
            const charCount = document.getElementById('charCount');
            
            // Store original values for comparison
            const originalValues = {
                bottleType: '<%= bottle.bottleType %>',
                status: '<%= bottle.status %>',
                batchNumber: '<%= bottle.batchNumber || "" %>',
                expiryDate: '<%= bottle.expiryDate %>',
                description: '<%= bottle.description || "" %>'
            };
            
            // Character count for description
            function updateCharCount() {
                const count = descriptionInput.value.length;
                charCount.textContent = count;
                charCount.className = count > 450 ? 'text-warning' : count > 480 ? 'text-danger' : '';
            }
            
            descriptionInput.addEventListener('input', updateCharCount);
            updateCharCount();

            // Form validation and submission
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Show loading state
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Updating...';
                
                // Submit after short delay to show loading state
                setTimeout(() => {
                    form.submit();
                }, 500);
            });

            // Warn about unsaved changes
            let hasUnsavedChanges = false;
            
            form.addEventListener('input', function() {
                hasUnsavedChanges = true;
            });
            
            form.addEventListener('change', function() {
                hasUnsavedChanges = true;
            });
            
            window.addEventListener('beforeunload', function(e) {
                if (hasUnsavedChanges) {
                    e.preventDefault();
                    e.returnValue = '';
                }
            });
            
            // Remove warning when form is submitted
            form.addEventListener('submit', function() {
                hasUnsavedChanges = false;
            });
        });

        // Reset form to original values
        function resetForm() {
            if (confirm('Are you sure you want to reset all changes?')) {
                document.getElementById('bottleType').value = '<%= bottle.bottleType %>';
                document.getElementById('status').value = '<%= bottle.status %>';
                document.getElementById('batchNumber').value = '<%= bottle.batchNumber || "" %>';
                document.getElementById('expiryDate').value = '<%= bottle.expiryDate %>';
                document.getElementById('description').value = '<%= bottle.description || "" %>';
                
                // Update character count
                document.getElementById('charCount').textContent = document.getElementById('description').value.length;
                
                utils.showToast('Form reset to original values', 'info');
            }
        }

        // Preview changes before saving
        function previewChanges() {
            const currentValues = {
                bottleType: document.getElementById('bottleType').value,
                status: document.getElementById('status').value,
                batchNumber: document.getElementById('batchNumber').value,
                expiryDate: document.getElementById('expiryDate').value,
                description: document.getElementById('description').value
            };
            
            const originalValues = {
                bottleType: '<%= bottle.bottleType %>',
                status: '<%= bottle.status %>',
                batchNumber: '<%= bottle.batchNumber || "" %>',
                expiryDate: '<%= bottle.expiryDate %>',
                description: '<%= bottle.description || "" %>'
            };
            
            const previewTableBody = document.getElementById('previewTableBody');
            previewTableBody.innerHTML = '';
            
            const fieldLabels = {
                bottleType: 'Bottle Type',
                status: 'Status',
                batchNumber: 'Batch Number',
                expiryDate: 'Expiry Date',
                description: 'Description'
            };
            
            let hasChanges = false;
            
            Object.keys(currentValues).forEach(field => {
                const current = originalValues[field];
                const newValue = currentValues[field];
                
                if (current !== newValue) {
                    hasChanges = true;
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td class="fw-bold">${fieldLabels[field]}</td>
                        <td class="text-muted">${current || '<em>Empty</em>'}</td>
                        <td class="text-primary">${newValue || '<em>Empty</em>'}</td>
                        <td><span class="badge bg-warning">Changed</span></td>
                    `;
                    previewTableBody.appendChild(row);
                }
            });
            
            if (!hasChanges) {
                previewTableBody.innerHTML = `
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="fas fa-info-circle fa-2x mb-2"></i>
                            <br>No changes detected
                        </td>
                    </tr>
                `;
            }
            
            const modal = new bootstrap.Modal(document.getElementById('previewModal'));
            modal.show();
        }

        // Submit form from preview modal
        function submitForm() {
            const modal = bootstrap.Modal.getInstance(document.getElementById('previewModal'));
            modal.hide();
            document.querySelector('form[data-validate]').submit();
        }

        // Auto-save functionality (optional)
        let autoSaveTimeout;
        const autoSaveEnabled = false; // Set to true to enable auto-save
        
        if (autoSaveEnabled) {
            document.querySelectorAll('input, select, textarea').forEach(input => {
                input.addEventListener('input', function() {
                    clearTimeout(autoSaveTimeout);
                    autoSaveTimeout = setTimeout(() => {
                        // Auto-save logic could go here
                        console.log('Auto-saving...');
                    }, 3000); // Auto-save after 3 seconds of inactivity
                });
            });
        }
    </script>
</body>
</html>