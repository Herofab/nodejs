<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="fas fa-wine-bottle"></i> Bottle Management</h1>
                    <div>
                        <a href="/bottles/add" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add New Bottle
                        </a>
                        <a href="/bottles/export" class="btn btn-success">
                            <i class="fas fa-download"></i> Export CSV
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4><%= statistics.total_bottles || 0 %></h4>
                                <p class="mb-0">Total Bottles</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-wine-bottle fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4><%= statistics.at_plant || 0 %></h4>
                                <p class="mb-0">At Plant</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-industry fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4><%= statistics.at_customer || 0 %></h4>
                                <p class="mb-0">At Customer</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-user fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4><%= statistics.at_vehicle || 0 %></h4>
                                <p class="mb-0">At Vehicle</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-truck fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="card bg-danger text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4><%= statistics.expired || 0 %></h4>
                                <p class="mb-0">Expired</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-exclamation-triangle fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
                <div class="card bg-secondary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4><%= statistics.expiring_soon || 0 %></h4>
                                <p class="mb-0">Expiring Soon</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-clock fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <form method="GET" action="/bottles" class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Status</label>
                                <select name="status" class="form-select">
                                    <option value="">All Status</option>
                                    <option value="AtPlant" <%= filters.status === 'AtPlant' ? 'selected' : '' %>>At Plant</option>
                                    <option value="AtCustomer" <%= filters.status === 'AtCustomer' ? 'selected' : '' %>>At Customer</option>
                                    <option value="AtVehicle" <%= filters.status === 'AtVehicle' ? 'selected' : '' %>>At Vehicle</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Bottle Type</label>
                                <select name="bottleType" class="form-select">
                                    <option value="">All Types</option>
                                    <option value="0.5L" <%= filters.bottleType === '0.5L' ? 'selected' : '' %>>0.5 Liter</option>
                                    <option value="1L" <%= filters.bottleType === '1L' ? 'selected' : '' %>>1 Liter</option>
                                    <option value="5L" <%= filters.bottleType === '5L' ? 'selected' : '' %>>5 Liter</option>
                                    <option value="20L" <%= filters.bottleType === '20L' ? 'selected' : '' %>>20 Liter</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Search</label>
                                <input type="text" name="search" class="form-control" 
                                       placeholder="Search by code, description, or batch..." 
                                       value="<%= filters.search || '' %>">
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-search"></i> Filter
                                </button>
                                <a href="/bottles" class="btn btn-secondary">
                                    <i class="fas fa-times"></i>
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottles Table -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-list"></i> Bottles List</h5>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="selectAll">
                            <label class="form-check-label" for="selectAll">
                                Select All
                            </label>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <% if (bottles.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-dark">
                                        <tr>
                                            <th><input type="checkbox" id="selectAllHeader"></th>
                                            <th>QR Code</th>
                                            <th>Code</th>
                                            <th>Type</th>
                                            <th>Status</th>
                                            <th>Description</th>
                                            <th>Manufacturing Date</th>
                                            <th>Expiry Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% bottles.forEach(function(bottle) { 
                                            const bottleData = bottle.toJSON ? bottle.toJSON() : bottle;
                                        %>
                                            <tr class="bottle-row" data-bottle-id="<%= bottleData.id %>" ondblclick="viewBottleDetail(this.dataset.bottleId)">
                                                <td>
                                                    <input type="checkbox" class="bottle-select" value="<%= bottleData.id %>">
                                                </td>
                                                <td>
                                                    <img src="<%= bottleData.qrCodeData %>" alt="QR Code" 
                                                         class="qr-code-img" width="50" height="50"
                                                         data-bs-toggle="modal" data-bs-target="#qrModal"
                                                         onclick="showQRCode('<%= bottleData.qrCodeData %>', '<%= bottleData.bottleCode %>')">
                                                </td>
                                                <td>
                                                    <strong class="text-primary"><%= bottleData.bottleCode %></strong>
                                                </td>
                                                <td>
                                                    <span class="badge bg-info"><%= bottleData.bottleType %></span>
                                                </td>
                                                <td>
                                                    <select class="form-select form-select-sm status-select" 
                                                            data-bottle-id="<%= bottleData.id %>" 
                                                            style="max-width: 120px;">
                                                        <option value="AtPlant" <%= bottleData.status === 'AtPlant' ? 'selected' : '' %>>At Plant</option>
                                                        <option value="AtCustomer" <%= bottleData.status === 'AtCustomer' ? 'selected' : '' %>>At Customer</option>
                                                        <option value="AtVehicle" <%= bottleData.status === 'AtVehicle' ? 'selected' : '' %>>At Vehicle</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <span title="<%= bottleData.description || 'No description' %>">
                                                        <%= (bottleData.description || '').length > 30 ? 
                                                            (bottleData.description || '').substring(0, 30) + '...' : 
                                                            (bottleData.description || 'No description') %>
                                                    </span>
                                                </td>
                                                <td><%= bottleData.manufacturingDate %></td>
                                                <td>
                                                    <span class="<%= bottleData.isExpired ? 'text-danger fw-bold' : 
                                                                     bottleData.isExpiringSoon ? 'text-warning fw-bold' : '' %>">
                                                        <%= bottleData.expiryDate %>
                                                    </span>
                                                    <% if (bottleData.isExpired) { %>
                                                        <i class="fas fa-exclamation-triangle text-danger ms-1" title="Expired"></i>
                                                    <% } else if (bottleData.isExpiringSoon) { %>
                                                        <i class="fas fa-clock text-warning ms-1" title="Expiring Soon"></i>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="/bottles/<%= bottleData.id %>" class="btn btn-outline-primary" title="View Details">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="/bottles/<%= bottleData.id %>/edit" class="btn btn-outline-warning" title="Edit">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form method="POST" action="/bottles/<%= bottleData.id %>/delete" class="d-inline">
                                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                            <button type="submit" class="btn btn-outline-danger" 
                                                                    onclick="return confirm('Are you sure you want to delete this bottle?')" title="Delete">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Bulk Actions -->
                            <div class="p-3 border-top">
                                <form method="POST" action="/bottles/bulk-action" id="bulkActionForm">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="bottleIds" id="bulkBottleIds">
                                    
                                    <div class="row align-items-center">
                                        <div class="col-md-6">
                                            <span id="selectedCount">0</span> bottle(s) selected
                                        </div>
                                        <div class="col-md-6">
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-secondary dropdown-toggle" data-bs-toggle="dropdown" disabled id="bulkActionBtn">
                                                    Bulk Actions
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" href="#" onclick="performBulkAction('AtPlant')">Move to Plant</a></li>
                                                    <li><a class="dropdown-item" href="#" onclick="performBulkAction('AtCustomer')">Move to Customer</a></li>
                                                    <li><a class="dropdown-item" href="#" onclick="performBulkAction('AtVehicle')">Move to Vehicle</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" href="#" onclick="performBulkAction('delete')">Delete Selected</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            <!-- Pagination -->
                            <% if (totalPages > 1) { %>
                                <div class="p-3 border-top">
                                    <nav>
                                        <ul class="pagination justify-content-center mb-0">
                                            <% if (currentPage > 1) { %>
                                                <li class="page-item">
                                                    <a class="page-link" href="/bottles?page=<%= currentPage - 1 %>&status=<%= filters.status || '' %>&bottleType=<%= filters.bottleType || '' %>&search=<%= filters.search || '' %>">Previous</a>
                                                </li>
                                            <% } %>
                                            
                                            <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                                <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                                    <a class="page-link" href="/bottles?page=<%= i %>&status=<%= filters.status || '' %>&bottleType=<%= filters.bottleType || '' %>&search=<%= filters.search || '' %>"><%= i %></a>
                                                </li>
                                            <% } %>
                                            
                                            <% if (currentPage < totalPages) { %>
                                                <li class="page-item">
                                                    <a class="page-link" href="/bottles?page=<%= currentPage + 1 %>&status=<%= filters.status || '' %>&bottleType=<%= filters.bottleType || '' %>&search=<%= filters.search || '' %>">Next</a>
                                                </li>
                                            <% } %>
                                        </ul>
                                    </nav>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="fas fa-wine-bottle fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No bottles found</h5>
                                <p class="text-muted">Start by adding your first bottle to the system.</p>
                                <a href="/bottles/add" class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Add First Bottle
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- QR Code Modal -->
    <div class="modal fade" id="qrModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">QR Code - <span id="qrBottleCode"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <img id="qrCodeImage" src="" alt="QR Code" class="img-fluid" style="max-width: 300px;">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" onclick="downloadQR()">
                        <i class="fas fa-download"></i> Download
                    </button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    <script src="/js/bottles.js"></script>
</body>
</html>