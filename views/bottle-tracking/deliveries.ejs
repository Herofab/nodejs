<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Water Plant Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../partials/header') %>
        </div>
    </div>

    <div class="container mt-4">
        <%- include('../partials/flash') %>
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-truck"></i> Bottle Delivery Tracking</h2>
            <div class="btn-group">
                <a href="/bottle-tracking" class="btn btn-outline-primary">
                    <i class="bi bi-qr-code-scan"></i> QR Scanner
                </a>
                <a href="/bottle-tracking/plant-operations" class="btn btn-outline-success">
                    <i class="bi bi-factory"></i> Plant Operations
                </a>
                <a href="/assignments/dispatch" class="btn btn-primary">
                    <i class="bi bi-dispatch-table"></i> Dispatch
                </a>
            </div>
        </div>

        <!-- Delivery Statistics -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-0">Today's Deliveries</h5>
                                <h3 class="mb-0"><%= stats.todayDeliveries || 0 %></h3>
                            </div>
                            <i class="bi bi-truck fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-0">Weekly Deliveries</h5>
                                <h3 class="mb-0"><%= stats.weeklyDeliveries || 0 %></h3>
                            </div>
                            <i class="bi bi-calendar-week fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-0">Bottles at Customers</h5>
                                <h3 class="mb-0"><%= stats.bottlesAtCustomers || 0 %></h3>
                            </div>
                            <i class="bi bi-people fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-0">Monthly Total</h5>
                                <h3 class="mb-0"><%= stats.monthlyDeliveries || 0 %></h3>
                            </div>
                            <i class="bi bi-calendar-month fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search Section -->
        <div class="card mb-4">
            <div class="card-header">
                <h5><i class="bi bi-search"></i> Search Bottle Deliveries</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <input type="text" id="searchInput" class="form-control" placeholder="Search by bottle code, customer name, or order ID...">
                    </div>
                    <div class="col-md-4">
                        <button type="button" id="searchBtn" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                        <button type="button" id="clearBtn" class="btn btn-outline-secondary ms-2">
                            <i class="bi bi-x-lg"></i> Clear
                        </button>
                    </div>
                </div>
                
                <div id="searchResults" class="mt-3" style="display: none;">
                    <h6>Search Results:</h6>
                    <div id="searchResultsContainer"></div>
                </div>
            </div>
        </div>

        <!-- Bottles at Customers -->
        <div class="card">
            <div class="card-header">
                <h5><i class="bi bi-people-fill"></i> Bottles Currently at Customers</h5>
            </div>
            <div class="card-body">
                <% if (bottlesAtCustomers && bottlesAtCustomers.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Customer</th>
                                    <th>Bottle Code</th>
                                    <th>Delivered Date</th>
                                    <th>Order ID</th>
                                    <th>Driver</th>
                                    <th>Vehicle</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bottlesAtCustomers.forEach(bottle => { %>
                                    <tr>
                                        <td>
                                            <strong><%= bottle.customer_name %></strong><br>
                                            <small class="text-muted"><%= bottle.customer_address %></small>
                                        </td>
                                        <td>
                                            <code><%= bottle.bottle_code %></code>
                                        </td>
                                        <td>
                                            <span class="badge bg-success">
                                                <%= new Date(bottle.delivered_at).toLocaleDateString() %>
                                            </span><br>
                                            <small class="text-muted">
                                                <%= new Date(bottle.delivered_at).toLocaleTimeString() %>
                                            </small>
                                        </td>
                                        <td>
                                            <a href="/orders/<%= bottle.order_assignment_id %>" class="btn btn-sm btn-outline-primary">
                                                #<%= bottle.order_assignment_id %>
                                            </a>
                                        </td>
                                        <td><%= bottle.driver_name %></td>
                                        <td>
                                            <%= bottle.vehicle_plate %><br>
                                            <small class="text-muted"><%= bottle.vehicle_model %></small>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-info" onclick="viewBottleHistory('<%= bottle.bottle_code %>')">
                                                <i class="bi bi-clock-history"></i> History
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <h5 class="text-muted mt-3">No bottles currently at customers</h5>
                        <p class="text-muted">All delivered bottles have been returned or no deliveries yet.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Bottle History Modal -->
    <div class="modal fade" id="bottleHistoryModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Bottle History</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="bottleHistoryContent">
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Search functionality
        document.getElementById('searchBtn').addEventListener('click', performSearch);
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                performSearch();
            }
        });
        
        document.getElementById('clearBtn').addEventListener('click', function() {
            document.getElementById('searchInput').value = '';
            document.getElementById('searchResults').style.display = 'none';
        });

        async function performSearch() {
            const query = document.getElementById('searchInput').value.trim();
            if (!query) {
                alert('Please enter a search term');
                return;
            }

            try {
                const response = await fetch(`/bottle-tracking/deliveries/search?q=${encodeURIComponent(query)}`);
                const data = await response.json();

                if (data.success) {
                    displaySearchResults(data.results);
                } else {
                    alert('Error searching bottles: ' + data.error);
                }
            } catch (error) {
                console.error('Search error:', error);
                alert('Error performing search');
            }
        }

        function displaySearchResults(results) {
            const container = document.getElementById('searchResultsContainer');
            const resultsDiv = document.getElementById('searchResults');

            if (results.length === 0) {
                container.innerHTML = '<p class="text-muted">No results found.</p>';
            } else {
                let html = `
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Bottle Code</th>
                                    <th>Customer</th>
                                    <th>Delivered Date</th>
                                    <th>Order ID</th>
                                    <th>Driver</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                `;

                results.forEach(result => {
                    html += `
                        <tr>
                            <td><code>${result.bottle_code}</code></td>
                            <td>${result.customer_name}</td>
                            <td>${new Date(result.delivered_at).toLocaleDateString()}</td>
                            <td>#${result.order_assignment_id}</td>
                            <td>${result.driver_name}</td>
                            <td>
                                <button class="btn btn-sm btn-info" onclick="viewBottleHistory('${result.bottle_code}')">
                                    <i class="bi bi-clock-history"></i> History
                                </button>
                            </td>
                        </tr>
                    `;
                });

                html += '</tbody></table></div>';
                container.innerHTML = html;
            }

            resultsDiv.style.display = 'block';
        }

        async function viewBottleHistory(bottleCode) {
            const modal = new bootstrap.Modal(document.getElementById('bottleHistoryModal'));
            const content = document.getElementById('bottleHistoryContent');
            
            // Show loading
            content.innerHTML = `
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading history for bottle <code>${bottleCode}</code>...</p>
                </div>
            `;
            
            modal.show();

            try {
                const response = await fetch(`/bottle-tracking/bottle/${bottleCode}/history`);
                const data = await response.json();

                if (data.success) {
                    displayBottleHistory(data.history, bottleCode);
                } else {
                    content.innerHTML = `<div class="alert alert-danger">Error loading bottle history: ${data.error}</div>`;
                }
            } catch (error) {
                console.error('Error loading bottle history:', error);
                content.innerHTML = '<div class="alert alert-danger">Error loading bottle history</div>';
            }
        }

        function displayBottleHistory(history, bottleCode) {
            const content = document.getElementById('bottleHistoryContent');
            
            if (history.length === 0) {
                content.innerHTML = `
                    <div class="text-center py-4">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <h5 class="text-muted mt-3">No delivery history</h5>
                        <p class="text-muted">Bottle <code>${bottleCode}</code> has not been delivered yet.</p>
                    </div>
                `;
                return;
            }

            let html = `
                <h6><i class="bi bi-bottle"></i> History for Bottle: <code>${bottleCode}</code></h6>
                <div class="timeline">
            `;

            history.forEach((entry, index) => {
                html += `
                    <div class="timeline-item ${index === 0 ? 'timeline-item-recent' : ''}">
                        <div class="timeline-marker">
                            <i class="bi bi-truck-flatbed"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-title">
                                        Delivered to ${entry.customer_name}
                                        ${index === 0 ? '<span class="badge bg-success ms-2">Current</span>' : ''}
                                    </h6>
                                    <p class="card-text">
                                        <strong>Date:</strong> ${new Date(entry.delivered_at).toLocaleString()}<br>
                                        <strong>Order:</strong> #${entry.order_assignment_id}<br>
                                        <strong>Driver:</strong> ${entry.driver_name}<br>
                                        <strong>Vehicle:</strong> ${entry.vehicle_plate} (${entry.vehicle_model})<br>
                                        <strong>Address:</strong> ${entry.customer_address}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });

            html += '</div>';
            content.innerHTML = html;
        }
    </script>

    <style>
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        
        .timeline-item {
            position: relative;
            margin-bottom: 2rem;
        }
        
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -15px;
            top: 0;
            bottom: -2rem;
            width: 2px;
            background: #dee2e6;
        }
        
        .timeline-item:last-child::before {
            display: none;
        }
        
        .timeline-marker {
            position: absolute;
            left: -22px;
            top: 8px;
            width: 16px;
            height: 16px;
            background: #6c757d;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 8px;
        }
        
        .timeline-item-recent .timeline-marker {
            background: #28a745;
        }
        
        .timeline-content {
            margin-left: 15px;
        }
    </style>
</body>
</html>