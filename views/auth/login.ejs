<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('../partials/flash') %>
    
    <div class="container-fluid vh-100 d-flex align-items-center justify-content-center">
        <div class="row w-100">
            <div class="col-md-6 col-lg-4 mx-auto">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white text-center">
                        <h3><i class="fas fa-tachometer-alt"></i> Dashboard Login</h3>
                        <p class="mb-0">Choose your authentication method</p>
                    </div>
                    <div class="card-body">
                        <!-- Login Method Tabs -->
                        <ul class="nav nav-tabs nav-justified mb-4" id="loginTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="password-tab" data-bs-toggle="tab" data-bs-target="#password" type="button" role="tab">
                                    <i class="fas fa-key"></i> Password
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="pin-tab" data-bs-toggle="tab" data-bs-target="#pin" type="button" role="tab">
                                    <i class="fas fa-lock"></i> PIN
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="fingerprint-tab" data-bs-toggle="tab" data-bs-target="#fingerprint" type="button" role="tab">
                                    <i class="fas fa-fingerprint"></i> Fingerprint
                                </button>
                            </li>
                        </ul>

                        <!-- Tab Content -->
                        <div class="tab-content" id="loginTabContent">
                            <!-- Password Login -->
                            <div class="tab-pane fade show active" id="password" role="tabpanel">
                                <form action="/auth/login/password" method="POST" id="passwordForm">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    
                                    <div class="mb-3">
                                        <label for="email" class="form-label">
                                            <i class="fas fa-envelope"></i> Email Address
                                        </label>
                                        <input type="email" class="form-control" id="email" name="email" 
                                               value="<%= formData.email || '' %>" required>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="password" class="form-label">
                                            <i class="fas fa-lock"></i> Password
                                        </label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="password" name="password" required>
                                            <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <button type="submit" class="btn btn-primary w-100">
                                        <i class="fas fa-sign-in-alt"></i> Login with Password
                                    </button>
                                </form>
                            </div>

                            <!-- PIN Login -->
                            <div class="tab-pane fade" id="pin" role="tabpanel">
                                <form id="pinForm">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    
                                    <div class="mb-3">
                                        <label for="pinEmail" class="form-label">
                                            <i class="fas fa-envelope"></i> Email Address
                                        </label>
                                        <input type="email" class="form-control" id="pinEmail" name="email" required>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="pinCode" class="form-label">
                                            <i class="fas fa-lock"></i> PIN Code
                                        </label>
                                        <input type="password" class="form-control text-center" id="pinCode" name="pin" 
                                               maxlength="6" pattern="[0-9]{4,6}" placeholder="Enter 4-6 digit PIN" required>
                                    </div>
                                    
                                    <button type="submit" class="btn btn-warning w-100">
                                        <i class="fas fa-unlock"></i> Login with PIN
                                    </button>
                                </form>
                            </div>

                            <!-- Fingerprint Login -->
                            <div class="tab-pane fade" id="fingerprint" role="tabpanel">
                                <form id="fingerprintForm">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    
                                    <div class="mb-3">
                                        <label for="fingerprintEmail" class="form-label">
                                            <i class="fas fa-envelope"></i> Email Address
                                        </label>
                                        <input type="email" class="form-control" id="fingerprintEmail" name="email" required>
                                    </div>
                                    
                                    <div class="mb-3 text-center">
                                        <div class="fingerprint-scanner p-4 border rounded">
                                            <i class="fas fa-fingerprint fa-4x text-success mb-3"></i>
                                            <p class="mb-0">Click to scan fingerprint</p>
                                            <small class="text-muted">Simulated fingerprint scanner</small>
                                        </div>
                                        <input type="hidden" id="fingerprintData" name="fingerprintData">
                                    </div>
                                    
                                    <button type="submit" class="btn btn-success w-100" disabled id="fingerprintSubmit">
                                        <i class="fas fa-fingerprint"></i> Login with Fingerprint
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer text-center text-muted">
                        <small>
                            <i class="fas fa-shield-alt"></i> 
                            Secure multi-factor authentication system
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/login.js"></script>
</body>
</html>