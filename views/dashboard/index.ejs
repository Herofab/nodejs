<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="fas fa-tachometer-alt"></i> Dashboard</h1>
                    <span class="badge bg-primary">Welcome, <%= currentUser.email %></span>
                </div>
            </div>
        </div>

        <!-- Dashboard Stats -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3><%= users.length %></h3>
                                <p class="mb-0">Total Users</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-users fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3><%= users.filter(u => u.is_active).length %></h3>
                                <p class="mb-0">Active Users</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-user-check fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3><%= users.filter(u => u.role === 'admin').length %></h3>
                                <p class="mb-0">Administrators</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-user-shield fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3><%= new Date().toLocaleDateString() %></h3>
                                <p class="mb-0">Today</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-calendar fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-bolt"></i> Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Bottle Management -->
                            <div class="col-md-2 col-sm-6 mb-3">
                                <a href="/bottles" class="btn btn-primary w-100">
                                    <i class="fas fa-wine-bottle"></i> Bottles
                                </a>
                            </div>
                            <div class="col-md-2 col-sm-6 mb-3">
                                <a href="/bottles/add" class="btn btn-success w-100">
                                    <i class="fas fa-plus"></i> Add Bottle
                                </a>
                            </div>
                            
                            <!-- Customer Management -->
                            <div class="col-md-2 col-sm-6 mb-3">
                                <a href="/customers" class="btn btn-info w-100">
                                    <i class="fas fa-address-book"></i> Customers
                                </a>
                            </div>
                            <div class="col-md-2 col-sm-6 mb-3">
                                <a href="/customers/add" class="btn btn-success w-100">
                                    <i class="fas fa-user-plus"></i> Add Customer
                                </a>
                            </div>
                            
                            <!-- Order Management -->
                            <div class="col-md-2 col-sm-6 mb-3">
                                <a href="/orders" class="btn btn-warning w-100">
                                    <i class="fas fa-shopping-cart"></i> Orders
                                </a>
                            </div>
                            <div class="col-md-2 col-sm-6 mb-3">
                                <a href="/orders/add" class="btn btn-success w-100">
                                    <i class="fas fa-plus-circle"></i> New Order
                                </a>
                            </div>
                            
                            <!-- Second Row -->
                            <div class="col-md-3 col-sm-6 mb-3">
                                <a href="/orders/schedule/delivery" class="btn btn-dark w-100">
                                    <i class="fas fa-calendar-check"></i> Delivery Schedule
                                </a>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <a href="/orders/delivery/optimize" class="btn btn-secondary w-100">
                                    <i class="fas fa-route"></i> Delivery Routes
                                </a>
                            </div>
                            
                            <% if (currentUser.role === 'admin') { %>
                                <div class="col-md-3 col-sm-6 mb-3">
                                    <a href="/dashboard/users/add" class="btn btn-danger w-100">
                                        <i class="fas fa-user-plus"></i> Add User
                                    </a>
                                </div>
                                <div class="col-md-3 col-sm-6 mb-3">
                                    <a href="/dashboard/users" class="btn btn-outline-dark w-100">
                                        <i class="fas fa-users-cog"></i> Manage Users
                                    </a>
                                </div>
                            <% } else { %>
                                <div class="col-md-6 col-sm-12 mb-3">
                                    <a href="/dashboard/profile" class="btn btn-outline-info w-100">
                                        <i class="fas fa-user-cog"></i> My Profile
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Users Table -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-users"></i> Recent Users</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Last Login</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% users.slice(0, 10).forEach(function(user) { %>
                                        <tr>
                                            <td>
                                                <i class="fas fa-user"></i> <%= user.email %>
                                            </td>
                                            <td>
                                                <% if (user.role === 'admin') { %>
                                                    <span class="badge bg-danger">Admin</span>
                                                <% } else { %>
                                                    <span class="badge bg-primary">User</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (user.is_active) { %>
                                                    <span class="badge bg-success">Active</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Inactive</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (user.last_login) { %>
                                                    <%= new Date(user.last_login).toLocaleString() %>
                                                <% } else { %>
                                                    <span class="text-muted">Never</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <%= new Date(user.created_at).toLocaleDateString() %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>