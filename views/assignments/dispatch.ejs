<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        .assignment-card {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }
        .assignment-card:hover {
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .driver-section {
            background: #f8f9fa;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .unassigned-section {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 8px;
        }
        .priority-urgent { border-left: 4px solid #dc3545; }
        .priority-high { border-left: 4px solid #fd7e14; }
        .priority-normal { border-left: 4px solid #20c997; }
        .priority-low { border-left: 4px solid #6c757d; }
        .status-assigned { background-color: #e3f2fd; }
        .status-in_progress { background-color: #fff3e0; }
        .status-delivered { background-color: #e8f5e8; }
        .status-failed { background-color: #ffebee; }
        .drag-over { background-color: #e3f2fd; border: 2px dashed #2196f3; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="container-fluid mt-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h1><i class="fas fa-clipboard-list text-primary"></i> Daily Dispatch Board</h1>
                    <div class="btn-group">
                        <input type="date" class="form-control" id="dateSelector" value="<%= selectedDate %>" style="max-width: 200px;">
                        <button class="btn btn-success" onclick="autoAssignOrders()">
                            <i class="fas fa-magic"></i> Auto Assign
                        </button>
                        <button class="btn btn-info" onclick="optimizeRoutes()">
                            <i class="fas fa-route"></i> Optimize Routes
                        </button>
                        <a href="/assignments/report/workload?date=<%= selectedDate %>" class="btn btn-outline-secondary">
                            <i class="fas fa-chart-bar"></i> Workload Report
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Row -->
        <div class="row mb-4">
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h3><%= stats.total_assignments || 0 %></h3>
                        <p class="mb-0">Total Assignments</p>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center">
                        <h3><%= stats.pending || 0 %></h3>
                        <p class="mb-0">Pending</p>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h3><%= stats.in_progress || 0 %></h3>
                        <p class="mb-0">In Progress</p>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h3><%= stats.completed || 0 %></h3>
                        <p class="mb-0">Completed</p>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-danger text-white">
                    <div class="card-body text-center">
                        <h3><%= stats.failed || 0 %></h3>
                        <p class="mb-0">Failed</p>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-secondary text-white">
                    <div class="card-body text-center">
                        <h3><%= unassignedOrders.length %></h3>
                        <p class="mb-0">Unassigned</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Driver Assignments Column -->
            <div class="col-md-8">
                <h4>Driver Assignments</h4>
                
                <% if (availableDrivers.length === 0) { %>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        No active drivers available. Please add drivers first.
                    </div>
                <% } else { %>
                    <% availableDrivers.forEach(driver => { %>
                        <div class="driver-section p-3 mb-3" data-driver-id="<%= driver.id %>">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="mb-1">
                                        <i class="fas fa-user"></i> <%= driver.full_name %>
                                        <% if (driver.vehicle_license_plate) { %>
                                            <span class="badge bg-info ms-2">
                                                <i class="fas fa-car"></i> <%= driver.vehicle_license_plate %>
                                            </span>
                                        <% } %>
                                    </h5>
                                    <small class="text-muted">
                                        <i class="fas fa-phone"></i> <%= driver.phone_primary %>
                                    </small>
                                </div>
                                <div>
                                    <span class="badge bg-primary">
                                        <%= (assignmentsByDriver[driver.id] || []).length %> assignments
                                    </span>
                                </div>
                            </div>

                            <!-- Driver's Assignments -->
                            <div class="driver-assignments" data-driver-id="<%= driver.id %>" 
                                 ondrop="dropAssignment(event)" ondragover="allowDrop(event)">
                                <% if (assignmentsByDriver[driver.id] && assignmentsByDriver[driver.id].length > 0) { %>
                                    <% assignmentsByDriver[driver.id].forEach(assignment => { %>
                                        <div class="assignment-card priority-<%= assignment.priority_level %> status-<%= assignment.delivery_status %> p-3"
                                             data-assignment-id="<%= assignment.id %>" draggable="true" 
                                             ondragstart="dragAssignment(event)">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div class="flex-grow-1">
                                                    <h6 class="mb-1">
                                                        <strong><%= assignment.order_number %></strong>
                                                        <span class="badge bg-<%= assignment.priority_level === 'urgent' ? 'danger' : assignment.priority_level === 'high' ? 'warning' : 'secondary' %> ms-2">
                                                            <%= assignment.priority_level %>
                                                        </span>
                                                    </h6>
                                                    <p class="mb-1">
                                                        <i class="fas fa-user"></i> <%= assignment.customer_name %>
                                                        <br><small class="text-muted">
                                                            <i class="fas fa-phone"></i> <%= assignment.customer_phone %>
                                                        </small>
                                                    </p>
                                                    <p class="mb-2">
                                                        <i class="fas fa-map-marker-alt"></i> <%= assignment.customer_address %>
                                                    </p>
                                                    <p class="mb-2">
                                                        <i class="fas fa-bottle-water"></i> <%= assignment.bottle_type %> × <%= assignment.quantity_per_delivery %>
                                                        <% if (assignment.estimated_delivery_time) { %>
                                                            <span class="ms-3">
                                                                <i class="fas fa-clock"></i> <%= assignment.estimated_delivery_time %>
                                                            </span>
                                                        <% } %>
                                                    </p>
                                                </div>
                                                <div class="btn-group-vertical btn-group-sm">
                                                    <button class="btn btn-outline-success btn-sm" 
                                                            onclick="updateStatus('<%= assignment.id %>', 'in_progress')"
                                                            title="Start Delivery">
                                                        <i class="fas fa-play"></i>
                                                    </button>
                                                    <button class="btn btn-outline-primary btn-sm" 
                                                            onclick="updateStatus('<%= assignment.id %>', 'delivered')"
                                                            title="Mark Delivered">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                    <button class="btn btn-outline-warning btn-sm" 
                                                            onclick="updateStatus('<%= assignment.id %>', 'failed')"
                                                            title="Mark Failed">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm" 
                                                            onclick="removeAssignment('<%= assignment.id %>')"
                                                            title="Remove Assignment">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            
                                            <!-- Status Badge -->
                                            <div class="mt-2">
                                                <span class="badge bg-<%= assignment.delivery_status === 'delivered' ? 'success' : assignment.delivery_status === 'failed' ? 'danger' : assignment.delivery_status === 'in_progress' ? 'info' : 'secondary' %>">
                                                    <i class="fas fa-<%= assignment.delivery_status === 'delivered' ? 'check-circle' : assignment.delivery_status === 'failed' ? 'times-circle' : assignment.delivery_status === 'in_progress' ? 'spinner' : 'clock' %>"></i>
                                                    <%= assignment.delivery_status.replace('_', ' ').toUpperCase() %>
                                                </span>
                                                <% if (assignment.delivery_sequence) { %>
                                                    <span class="badge bg-light text-dark ms-2">
                                                        Seq: <%= assignment.delivery_sequence %>
                                                    </span>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="text-center py-3 text-muted">
                                        <i class="fas fa-inbox fa-2x mb-2"></i>
                                        <p>No assignments yet</p>
                                        <small>Drag orders here to assign</small>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>

            <!-- Unassigned Orders Column -->
            <div class="col-md-4">
                <div class="unassigned-section p-3">
                    <h4 class="mb-3">
                        <i class="fas fa-exclamation-triangle text-warning"></i> 
                        Unassigned Orders (<%= unassignedOrders.length %>)
                    </h4>
                    
                    <% if (unassignedOrders.length === 0) { %>
                        <div class="text-center py-4">
                            <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                            <h6 class="text-success">All orders assigned!</h6>
                            <p class="text-muted">No pending orders for this date.</p>
                        </div>
                    <% } else { %>
                        <div id="unassigned-orders">
                            <% unassignedOrders.forEach(order => { %>
                                <div class="assignment-card priority-<%= order.priority_level %> p-3" 
                                     data-order-id="<%= order.id %>" draggable="true" 
                                     ondragstart="dragOrder(event)">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1">
                                                <strong><%= order.order_number %></strong>
                                                <span class="badge bg-<%= order.priority_level === 'urgent' ? 'danger' : order.priority_level === 'high' ? 'warning' : 'secondary' %> ms-2">
                                                    <%= order.priority_level %>
                                                </span>
                                            </h6>
                                            <p class="mb-1">
                                                <i class="fas fa-user"></i> <%= order.customer_name %>
                                                <br><small class="text-muted">
                                                    <i class="fas fa-phone"></i> <%= order.customer_phone %>
                                                </small>
                                            </p>
                                            <p class="mb-2">
                                                <i class="fas fa-map-marker-alt"></i> <%= order.customer_address %>
                                                <% if (order.customer_city) { %>
                                                    <br><small class="text-muted">
                                                        <i class="fas fa-city"></i> <%= order.customer_city %>
                                                    </small>
                                                <% } %>
                                            </p>
                                            <p class="mb-1">
                                                <i class="fas fa-bottle-water"></i> <%= order.bottle_type %> × <%= order.quantity_per_delivery %>
                                            </p>
                                        </div>
                                        <div>
                                            <button class="btn btn-sm btn-primary" 
                                                    onclick="showAssignModal('<%= order.id %>', '<%= order.order_number %>')">
                                                <i class="fas fa-user-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Assignment Modal -->
    <div class="modal fade" id="assignModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Assign Order</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="assignForm">
                    <div class="modal-body">
                        <input type="hidden" id="assign_order_id" name="order_id">
                        <input type="hidden" id="assign_date" name="assigned_date" value="<%= selectedDate %>">
                        
                        <div class="mb-3">
                            <label class="form-label">Order</label>
                            <div id="order_display" class="form-control-plaintext bg-light p-2 rounded"></div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="assign_driver_id" class="form-label">Driver <span class="text-danger">*</span></label>
                            <select class="form-select" id="assign_driver_id" name="driver_id" required>
                                <option value="">Select Driver</option>
                                <% availableDrivers.forEach(driver => { %>
                                    <option value="<%= driver.id %>" data-vehicle-id="<%= driver.assigned_vehicle_id || '' %>">
                                        <%= driver.full_name %>
                                        <% if (driver.vehicle_license_plate) { %>
                                            - <%= driver.vehicle_license_plate %> (<%= driver.vehicle_type %>)
                                        <% } else { %>
                                            - No vehicle assigned
                                        <% } %>
                                    </option>
                                <% }); %>
                            </select>
                            <div class="form-text">Driver's assigned vehicle will be automatically selected</div>
                        </div>
                        
                        <!-- Hidden vehicle input that gets auto-filled -->
                        <input type="hidden" id="assign_vehicle_id" name="vehicle_id">
                        
                        <div class="row">
                            <div class="col-md-6">
                                <label for="delivery_sequence" class="form-label">Delivery Sequence</label>
                                <input type="number" class="form-control" id="delivery_sequence" name="delivery_sequence" min="1">
                            </div>
                            <div class="col-md-6">
                                <label for="estimated_delivery_time" class="form-label">Estimated Time</label>
                                <input type="time" class="form-control" id="estimated_delivery_time" name="estimated_delivery_time">
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="assign_notes" class="form-label">Notes</label>
                            <textarea class="form-control" id="assign_notes" name="notes" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Assign Order</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Auto Assign Modal -->
    <div class="modal fade" id="autoAssignModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Auto Assign Orders</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/assignments/auto-assign" method="POST">
                    <div class="modal-body">
                        <input type="hidden" name="date" value="<%= selectedDate %>">
                        
                        <div class="mb-3">
                            <label for="maxOrdersPerDriver" class="form-label">Max Orders per Driver</label>
                            <input type="number" class="form-control" id="maxOrdersPerDriver" name="maxOrdersPerDriver" value="10" min="1" max="50">
                            <div class="form-text">Maximum number of orders to assign to each driver</div>
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            This will automatically assign unassigned orders to available drivers based on their current workload.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Auto Assign</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Date selector change
        document.getElementById('dateSelector').addEventListener('change', function() {
            window.location.href = '/assignments/dispatch?date=' + this.value;
        });

        // Drag and drop functionality
        function allowDrop(ev) {
            ev.preventDefault();
            ev.currentTarget.classList.add('drag-over');
        }

        function dragOrder(ev) {
            ev.dataTransfer.setData("order_id", ev.target.getAttribute('data-order-id'));
        }

        function dragAssignment(ev) {
            ev.dataTransfer.setData("assignment_id", ev.target.getAttribute('data-assignment-id'));
        }

        function dropAssignment(ev) {
            ev.preventDefault();
            ev.currentTarget.classList.remove('drag-over');
            
            const orderId = ev.dataTransfer.getData("order_id");
            const assignmentId = ev.dataTransfer.getData("assignment_id");
            const driverId = ev.currentTarget.getAttribute('data-driver-id');
            
            if (orderId) {
                // Assigning unassigned order to driver
                assignOrderToDriver(orderId, driverId);
            } else if (assignmentId) {
                // Moving assignment between drivers
                reassignOrder(assignmentId, driverId);
            }
        }

        // Remove drag-over class when drag leaves
        document.addEventListener('dragleave', function(ev) {
            ev.currentTarget.classList.remove('drag-over');
        });

        function assignOrderToDriver(orderId, driverId) {
            // Find the driver's vehicle from the available drivers data
            const driverSelect = document.getElementById('assign_driver_id');
            let vehicleId = null;
            
            // Look for the driver's assigned vehicle
            for (let option of driverSelect.options) {
                if (option.value === driverId) {
                    vehicleId = option.getAttribute('data-vehicle-id');
                    break;
                }
            }
            
            const formData = new FormData();
            formData.append('order_id', orderId);
            formData.append('driver_id', driverId);
            if (vehicleId) {
                formData.append('vehicle_id', vehicleId);
            }
            formData.append('assigned_date', '<%= selectedDate %>');
            
            console.log('Drag-and-drop assignment:', { orderId, driverId, vehicleId });
            
            fetch('/assignments/assign', {
                method: 'POST',
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + (data.error || 'Failed to assign order'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to assign order');
            });
        }

        function showAssignModal(orderId, orderNumber) {
            document.getElementById('assign_order_id').value = orderId;
            document.getElementById('order_display').textContent = orderNumber;
            new bootstrap.Modal(document.getElementById('assignModal')).show();
        }

        function autoAssignOrders() {
            new bootstrap.Modal(document.getElementById('autoAssignModal')).show();
        }

        function optimizeRoutes() {
            if (confirm('This will optimize delivery routes for all drivers. Continue?')) {
                fetch(`/assignments/optimize-routes/<%= selectedDate %>`, {
                    method: 'POST'
                })
                .then(() => {
                    location.reload();
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to optimize routes');
                });
            }
        }

        function updateStatus(assignmentId, newStatus) {
            fetch(`/assignments/${assignmentId}/status`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ status: newStatus })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + (data.error || 'Failed to update status'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to update status');
            });
        }

        function removeAssignment(assignmentId) {
            if (confirm('Are you sure you want to remove this assignment?')) {
                fetch(`/assignments/${assignmentId}`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + (data.error || 'Failed to remove assignment'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to remove assignment');
                });
            }
        }

        // Handle assign form submission
        document.getElementById('assignForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            
            // Debug: log form data
            console.log('Form submission data:');
            for (let [key, value] of formData.entries()) {
                console.log(`${key}: ${value}`);
            }
            
            fetch('/assignments/assign', {
                method: 'POST',
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            })
            .then(response => {
                console.log('Response status:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data);
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('assignModal')).hide();
                    alert('Order assigned successfully!'); // Temporary success message
                    location.reload();
                } else {
                    alert('Error: ' + (data.error || 'Failed to assign order'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to assign order: ' + error.message);
            });
        });

        // Auto-select vehicle when driver is chosen
        document.getElementById('assign_driver_id').addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const vehicleId = selectedOption.getAttribute('data-vehicle-id');
            document.getElementById('assign_vehicle_id').value = vehicleId || '';
        });
    </script>
</body>
</html>