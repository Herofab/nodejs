<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="container mt-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item"><a href="/orders">Orders</a></li>
                        <li class="breadcrumb-item"><a href="/orders/<%= order.id %>">Order #<%= order.order_number %></a></li>
                        <li class="breadcrumb-item active">Edit Order</li>
                    </ol>
                </nav>
                <h1><i class="fas fa-edit text-warning"></i> Edit Order #<%= order.order_number %></h1>
                <p class="text-muted">Customer: <%= order.customer_name %></p>
            </div>
        </div>

        <!-- Edit Order Form -->
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-shopping-cart"></i> Order Information</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="/orders/<%= order.id %>/edit" id="editOrderForm">
                            <!-- Order Status -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Order Status</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="status" class="form-label">Order Status <span class="text-danger">*</span></label>
                                    <select class="form-select" id="status" name="status" required>
                                        <option value="pending" <%= order.order_status === 'pending' ? 'selected' : '' %>>Pending</option>
                                        <option value="confirmed" <%= order.order_status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                        <option value="in-progress" <%= order.order_status === 'in-progress' ? 'selected' : '' %>>In Progress</option>
                                        <option value="paused" <%= order.order_status === 'paused' ? 'selected' : '' %>>Paused</option>
                                        <option value="completed" <%= order.order_status === 'completed' ? 'selected' : '' %>>Completed</option>
                                        <option value="cancelled" <%= order.order_status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="priority_level" class="form-label">Priority Level</label>
                                    <select class="form-select" id="priority_level" name="priority_level">
                                        <option value="low" <%= order.priority_level === 'low' ? 'selected' : '' %>>Low</option>
                                        <option value="normal" <%= order.priority_level === 'normal' ? 'selected' : '' %>>Normal</option>
                                        <option value="high" <%= order.priority_level === 'high' ? 'selected' : '' %>>High</option>
                                        <option value="urgent" <%= order.priority_level === 'urgent' ? 'selected' : '' %>>Urgent</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Customer Information (Read-only) -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Customer Information</h6>
                                </div>
                                <div class="col-12">
                                    <div class="alert alert-info">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <strong>Customer:</strong> <%= order.customer_name %><br>
                                                <strong>Code:</strong> <%= order.customer_code %><br>
                                                <strong>Phone:</strong> <%= order.customer_phone %>
                                            </div>
                                            <div class="col-md-6">
                                                <strong>Customer ID:</strong> <%= order.customer_id %><br>
                                                <strong>City:</strong> <%= order.city %><br>
                                                <a href="/customers/<%= order.customer_id %>" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-external-link-alt"></i> View Customer
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Order Details -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Order Details</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="order_type" class="form-label">Order Type</label>
                                    <select class="form-select" id="order_type" name="order_type" disabled>
                                        <option value="subscription" <%= order.order_type === 'subscription' ? 'selected' : '' %>>Subscription</option>
                                        <option value="on-demand" <%= order.order_type === 'on-demand' ? 'selected' : '' %>>On-Demand</option>
                                    </select>
                                    <small class="text-muted">Order type cannot be changed after creation</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="subscription_type" class="form-label">Subscription Type</label>
                                    <select class="form-select" id="subscription_type" name="subscription_type" 
                                            <%= order.order_type !== 'subscription' ? 'disabled' : '' %>>
                                        <option value="">Select Subscription</option>
                                        <option value="monthly" <%= order.subscription_type === 'monthly' ? 'selected' : '' %>>Monthly</option>
                                        <option value="parallel-1day" <%= order.subscription_type === 'parallel-1day' ? 'selected' : '' %>>Every Day</option>
                                        <option value="parallel-2day" <%= order.subscription_type === 'parallel-2day' ? 'selected' : '' %>>Every 2 Days</option>
                                        <option value="parallel-3day" <%= order.subscription_type === 'parallel-3day' ? 'selected' : '' %>>Every 3 Days</option>
                                        <option value="custom-dates" <%= order.subscription_type === 'custom-dates' ? 'selected' : '' %>>Custom Dates</option>
                                    </select>
                                </div>

                                <!-- Custom Dates (if applicable) -->
                                <% if (order.subscription_type === 'custom-dates' && order.custom_delivery_dates) { %>
                                <div class="col-12 mb-3">
                                    <label class="form-label">Current Custom Delivery Days</label>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <% JSON.parse(order.custom_delivery_dates).forEach(day => { %>
                                            <span class="badge bg-info fs-6"><%= day %><sup><%= day === 1 || day === 21 || day === 31 ? 'st' : day === 2 || day === 22 ? 'nd' : day === 3 || day === 23 ? 'rd' : 'th' %></sup></span>
                                        <% }); %>
                                    </div>
                                    <small class="text-muted">Contact administrator to modify custom delivery dates</small>
                                </div>
                                <% } %>

                                <div class="col-md-4 mb-3">
                                    <label for="bottle_type" class="form-label">Bottle Type <span class="text-danger">*</span></label>
                                    <select class="form-select" id="bottle_type" name="bottle_type" required>
                                        <option value="0.5L" <%= order.bottle_type === '0.5L' ? 'selected' : '' %>>0.5 Liter</option>
                                        <option value="1L" <%= order.bottle_type === '1L' ? 'selected' : '' %>>1 Liter</option>
                                        <option value="5L" <%= order.bottle_type === '5L' ? 'selected' : '' %>>5 Liter</option>
                                        <option value="20L" <%= order.bottle_type === '20L' ? 'selected' : '' %>>20 Liter</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="quantity_per_delivery" class="form-label">Quantity per Delivery <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control" id="quantity_per_delivery" name="quantity_per_delivery" 
                                           min="1" value="<%= order.quantity_per_delivery %>" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="unit_price" class="form-label">Unit Price (Rs.) <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control" id="unit_price" name="unit_price" 
                                           min="0" step="0.01" value="<%= order.unit_price %>" required>
                                </div>
                            </div>

                            <!-- Delivery Schedule -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Delivery Schedule</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="start_date" class="form-label">Start Date</label>
                                    <input type="date" class="form-control" id="start_date" name="start_date" 
                                           value="<%= order.start_date.toISOString().split('T')[0] %>" disabled>
                                    <small class="text-muted">Start date cannot be modified after creation</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="end_date" class="form-label">End Date</label>
                                    <input type="date" class="form-control" id="end_date" name="end_date" 
                                           value="<%= order.end_date ? order.end_date.toISOString().split('T')[0] : '' %>">
                                    <small class="text-muted">Leave empty for ongoing subscription</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="total_bottles_ordered" class="form-label">Total Bottles</label>
                                    <input type="number" class="form-control" id="total_bottles_ordered" name="total_bottles_ordered" 
                                           min="1" value="<%= order.total_bottles_ordered || '' %>" placeholder="Auto-calculated">
                                    <small class="text-muted">Leave empty to auto-calculate based on schedule</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="next_delivery_date" class="form-label">Next Delivery Date</label>
                                    <input type="date" class="form-control" id="next_delivery_date" name="next_delivery_date" 
                                           value="<%= order.next_delivery_date ? order.next_delivery_date.toISOString().split('T')[0] : '' %>">
                                    <small class="text-muted">Override automatic calculation</small>
                                </div>
                            </div>

                            <!-- Delivery Information -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Delivery Information</h6>
                                </div>
                                <div class="col-12 mb-3">
                                    <label for="delivery_address" class="form-label">Delivery Address</label>
                                    <textarea class="form-control" id="delivery_address" name="delivery_address" 
                                              rows="2" placeholder="Leave empty to use customer's address"><%= order.delivery_address || '' %></textarea>
                                </div>
                                <div class="col-12 mb-3">
                                    <label for="delivery_instructions" class="form-label">Delivery Instructions</label>
                                    <textarea class="form-control" id="delivery_instructions" name="delivery_instructions" 
                                              rows="3" placeholder="Special delivery instructions, gate codes, etc."><%= order.delivery_instructions || '' %></textarea>
                                </div>
                                <div class="col-12 mb-3">
                                    <label for="notes" class="form-label">Order Notes</label>
                                    <textarea class="form-control" id="notes" name="notes" rows="3" 
                                              placeholder="Any additional notes about this order"><%= order.notes || '' %></textarea>
                                </div>
                            </div>

                            <!-- Order Progress -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h6 class="border-bottom pb-2 mb-3">Order Progress</h6>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Bottles Delivered</label>
                                    <input type="number" class="form-control" value="<%= order.bottles_delivered %>" disabled>
                                    <small class="text-muted">Updated through delivery records</small>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Completed Deliveries</label>
                                    <input type="number" class="form-control" value="<%= order.completed_deliveries || 0 %>" disabled>
                                    <small class="text-muted">Auto-calculated</small>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Total Deliveries</label>
                                    <input type="number" class="form-control" value="<%= order.total_deliveries || 'Ongoing' %>" disabled>
                                    <small class="text-muted">Based on subscription type</small>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="row">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between">
                                        <a href="/orders/<%= order.id %>" class="btn btn-secondary">
                                            <i class="fas fa-arrow-left"></i> Back to Order
                                        </a>
                                        <div>
                                            <button type="reset" class="btn btn-outline-warning me-2">
                                                <i class="fas fa-undo"></i> Reset Changes
                                            </button>
                                            <button type="submit" class="btn btn-success">
                                                <i class="fas fa-save"></i> Save Changes
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Information Sidebar -->
            <div class="col-md-4">
                <!-- Order Summary -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h6><i class="fas fa-info-circle"></i> Current Order Summary</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless table-sm">
                            <tr>
                                <th>Order Number:</th>
                                <td>#<%= order.order_number %></td>
                            </tr>
                            <tr>
                                <th>Created:</th>
                                <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                            </tr>
                            <tr>
                                <th>Current Status:</th>
                                <td>
                                    <span class="badge bg-<%= order.order_status === 'confirmed' || order.order_status === 'in-progress' ? 'success' : order.order_status === 'paused' ? 'warning' : order.order_status === 'completed' ? 'primary' : 'danger' %>">
                                        <%= (order.order_status || 'pending').toUpperCase() %>
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Progress:</th>
                                <td><%= order.bottles_delivered %>/<%= order.total_bottles_ordered || '∞' %> bottles</td>
                            </tr>
                            <tr>
                                <th>Total Value:</th>
                                <td>Rs. <%= (order.bottles_delivered * order.unit_price).toLocaleString() %></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Change History -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h6><i class="fas fa-history"></i> Recent Activity</h6>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            <div class="timeline-item">
                                <small class="text-muted">Order Created</small>
                                <p class="mb-1"><%= new Date(order.created_at).toLocaleDateString() %></p>
                            </div>
                            <% if (order.updated_at && order.updated_at !== order.created_at) { %>
                            <div class="timeline-item">
                                <small class="text-muted">Last Modified</small>
                                <p class="mb-1"><%= new Date(order.updated_at).toLocaleDateString() %></p>
                            </div>
                            <% } %>
                            <% if (order.last_delivery_date) { %>
                            <div class="timeline-item">
                                <small class="text-muted">Last Delivery</small>
                                <p class="mb-1"><%= new Date(order.last_delivery_date).toLocaleDateString() %></p>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card">
                    <div class="card-header">
                        <h6><i class="fas fa-bolt"></i> Quick Actions</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-success btn-sm" onclick="recordDelivery()">
                                <i class="fas fa-truck"></i> Record Delivery
                            </button>
                            <a href="/orders/<%= order.id %>/schedule" class="btn btn-info btn-sm">
                                <i class="fas fa-calendar-plus"></i> View Schedule
                            </a>
                            <a href="/orders" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-list"></i> All Orders
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Enable/disable subscription type based on order type
            const orderTypeSelect = document.getElementById('order_type');
            const subscriptionTypeSelect = document.getElementById('subscription_type');
            
            // Form validation
            document.getElementById('editOrderForm').addEventListener('submit', function(e) {
                const status = document.getElementById('status').value;
                const bottleType = document.getElementById('bottle_type').value;
                const quantity = document.getElementById('quantity_per_delivery').value;
                const unitPrice = document.getElementById('unit_price').value;
                
                if (!status || !bottleType || !quantity || !unitPrice) {
                    e.preventDefault();
                    alert('Please fill in all required fields.');
                    return;
                }
                
                if (confirm('Are you sure you want to save these changes?')) {
                    return true;
                } else {
                    e.preventDefault();
                }
            });
            
            // Auto-save draft (optional)
            let saveTimeout;
            const formInputs = document.querySelectorAll('#editOrderForm input, #editOrderForm select, #editOrderForm textarea');
            
            formInputs.forEach(input => {
                if (!input.disabled) {
                    input.addEventListener('input', function() {
                        clearTimeout(saveTimeout);
                        saveTimeout = setTimeout(saveDraft, 2000);
                    });
                }
            });
        });

        function recordDelivery() {
            window.location.href = `/orders/<%= order.id %>?recordDelivery=true`;
        }

        function saveDraft() {
            // Optional: Auto-save functionality
            console.log('Auto-saving draft...');
        }

        // Calculate estimated totals when values change
        function updateEstimates() {
            const quantity = parseInt(document.getElementById('quantity_per_delivery').value) || 0;
            const unitPrice = parseFloat(document.getElementById('unit_price').value) || 0;
            const totalBottles = parseInt(document.getElementById('total_bottles_ordered').value) || 0;
            
            if (totalBottles > 0) {
                const estimatedTotal = totalBottles * unitPrice;
                console.log('Estimated total:', estimatedTotal);
            }
        }

        // Add event listeners for calculation
        ['quantity_per_delivery', 'unit_price', 'total_bottles_ordered'].forEach(id => {
            const element = document.getElementById(id);
            if (element) {
                element.addEventListener('input', updateEstimates);
            }
        });
    </script>
</body>
</html>