<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="container mt-4">
        <!-- Header Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h1><i class="fas fa-shopping-cart text-primary"></i> Order Management</h1>
                    <div class="btn-group">
                        <a href="/orders/add" class="btn btn-success">
                            <i class="fas fa-plus-circle"></i> New Order
                        </a>
                        <a href="/orders/schedule/delivery" class="btn btn-info">
                            <i class="fas fa-calendar-check"></i> Delivery Schedule
                        </a>
                        <a href="/orders/export/csv" class="btn btn-outline-secondary">
                            <i class="fas fa-download"></i> Export CSV
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3><%= orders ? orders.length : 0 %></h3>
                                <p class="mb-0">Total Orders</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-shopping-cart fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3>
                                    <%= orders ? orders.filter(o => o.order_status === 'confirmed' || o.order_status === 'in-progress').length : 0 %>
                                </h3>
                                <p class="mb-0">Active Orders</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-check-circle fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3>
                                    <%= orders ? orders.filter(o => o.order_type === 'subscription').length : 0 %>
                                </h3>
                                <p class="mb-0">Subscriptions</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-sync fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h3>
                                    <%= orders ? orders.filter(o => o.order_status === 'pending').length : 0 %>
                                </h3>
                                <p class="mb-0">Pending Orders</p>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-clock fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Today's Deliveries Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fas fa-truck"></i> Today's Deliveries
                                <span class="badge bg-light text-danger ms-2" id="todayDeliveriesCount">0</span>
                            </h5>
                            <div class="btn-group">
                                <button class="btn btn-light btn-sm" onclick="refreshTodayDeliveries()">
                                    <i class="fas fa-sync"></i> Refresh
                                </button>
                                <a href="/orders/schedule/delivery" class="btn btn-light btn-sm">
                                    <i class="fas fa-calendar-check"></i> Full Schedule
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div id="todayDeliveriesContent" style="max-height: 400px; overflow-y: auto; padding: 1rem; border-top: 1px solid rgba(255,255,255,0.2);">
                            <!-- Today's deliveries will be loaded here -->
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mt-2">Loading today's deliveries...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search and Filter Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <form method="GET" action="/orders" class="row g-3">
                            <div class="col-md-3">
                                <label for="search" class="form-label">Search</label>
                                <input type="text" class="form-control" id="search" name="search" 
                                       value="<%= filters.search %>" placeholder="Order number, customer name...">
                            </div>
                            <div class="col-md-2">
                                <label for="order_status" class="form-label">Status</label>
                                <select class="form-select" id="order_status" name="order_status">
                                    <option value="">All Status</option>
                                    <option value="pending" <%= filters.order_status === 'pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="confirmed" <%= filters.order_status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                    <option value="in-progress" <%= filters.order_status === 'in-progress' ? 'selected' : '' %>>In Progress</option>
                                    <option value="completed" <%= filters.order_status === 'completed' ? 'selected' : '' %>>Completed</option>
                                    <option value="cancelled" <%= filters.order_status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="order_type" class="form-label">Type</label>
                                <select class="form-select" id="order_type" name="order_type">
                                    <option value="">All Types</option>
                                    <option value="subscription" <%= filters.order_type === 'subscription' ? 'selected' : '' %>>Subscription</option>
                                    <option value="on-demand" <%= filters.order_type === 'on-demand' ? 'selected' : '' %>>On-Demand</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="bottle_type" class="form-label">Bottle Type</label>
                                <select class="form-select" id="bottle_type" name="bottle_type">
                                    <option value="">All Bottles</option>
                                    <option value="0.5L" <%= filters.bottle_type === '0.5L' ? 'selected' : '' %>>0.5L</option>
                                    <option value="1L" <%= filters.bottle_type === '1L' ? 'selected' : '' %>>1L</option>
                                    <option value="5L" <%= filters.bottle_type === '5L' ? 'selected' : '' %>>5L</option>
                                    <option value="20L" <%= filters.bottle_type === '20L' ? 'selected' : '' %>>20L</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">&nbsp;</label>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-search"></i> Search
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-1">
                                <label class="form-label">&nbsp;</label>
                                <div class="d-grid">
                                    <a href="/orders" class="btn btn-outline-secondary">
                                        <i class="fas fa-times"></i>
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders Table -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="fas fa-list"></i> Orders List</h5>
                            <span class="badge bg-primary">
                                <%= pagination ? pagination.total : 0 %> Total Orders
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <% if (orders && orders.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Order #</th>
                                            <th>Customer</th>
                                            <th>Type</th>
                                            <th>Bottles</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th>Next Delivery</th>
                                            <th>Progress</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% orders.forEach(function(order) { %>
                                            <tr onclick="window.location='/orders/<%= order.id %>'" style="cursor: pointer;">
                                                <td>
                                                    <strong><%= order.order_number %></strong>
                                                    <br><small class="text-muted">
                                                        <%= new Date(order.created_at).toLocaleDateString() %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <div>
                                                        <i class="fas fa-user text-primary"></i>
                                                        <strong><%= order.customer_name || 'N/A' %></strong>
                                                    </div>
                                                    <small class="text-muted">
                                                        <%= order.customer_code || '' %>
                                                        <%= order.customer_phone ? ' • ' + order.customer_phone : '' %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <% if (order.order_type === 'subscription') { %>
                                                        <span class="badge bg-info">
                                                            <i class="fas fa-sync"></i> Subscription
                                                        </span>
                                                        <% if (order.subscription_type) { %>
                                                            <br><small class="text-muted">
                                                                <%= order.subscription_type.replace('-', ' ') %>
                                                            </small>
                                                        <% } %>
                                                    <% } else { %>
                                                        <span class="badge bg-warning text-dark">
                                                            <i class="fas fa-shopping-bag"></i> On-Demand
                                                        </span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <div>
                                                        <strong><%= order.bottle_type %></strong>
                                                        <span class="text-muted">× <%= order.quantity_per_delivery %></span>
                                                    </div>
                                                    <small class="text-muted">
                                                        Total: <%= order.total_bottles_ordered %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <strong>Rs. <%= parseFloat(order.total_amount).toLocaleString() %></strong>
                                                    <br><small class="text-muted">
                                                        @ Rs. <%= parseFloat(order.unit_price).toFixed(2) %> each
                                                    </small>
                                                </td>
                                                <td>
                                                    <% if (order.order_status === 'pending') { %>
                                                        <span class="badge bg-warning text-dark">Pending</span>
                                                    <% } else if (order.order_status === 'confirmed') { %>
                                                        <span class="badge bg-primary">Confirmed</span>
                                                    <% } else if (order.order_status === 'in-progress') { %>
                                                        <span class="badge bg-info">In Progress</span>
                                                    <% } else if (order.order_status === 'completed') { %>
                                                        <span class="badge bg-success">Completed</span>
                                                    <% } else { %>
                                                        <span class="badge bg-danger">Cancelled</span>
                                                    <% } %>
                                                    
                                                    <% if (order.payment_status) { %>
                                                        <br><small class="badge badge-sm bg-secondary">
                                                            <%= order.payment_status %>
                                                        </small>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <% if (order.next_delivery_date && order.order_status !== 'completed') { %>
                                                        <div>
                                                            <%= new Date(order.next_delivery_date).toLocaleDateString() %>
                                                        </div>
                                                        <% 
                                                            const nextDate = new Date(order.next_delivery_date);
                                                            const today = new Date();
                                                            const diffTime = nextDate - today;
                                                            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                                        %>
                                                        <small class="<%= diffDays <= 1 ? 'text-danger' : diffDays <= 3 ? 'text-warning' : 'text-muted' %>">
                                                            <% if (diffDays === 0) { %>
                                                                Today
                                                            <% } else if (diffDays === 1) { %>
                                                                Tomorrow
                                                            <% } else if (diffDays > 0) { %>
                                                                In <%= diffDays %> days
                                                            <% } else { %>
                                                                <%= Math.abs(diffDays) %> days overdue
                                                            <% } %>
                                                        </small>
                                                    <% } else { %>
                                                        <span class="text-muted">-</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <% 
                                                        const delivered = parseInt(order.bottles_delivered) || 0;
                                                        const total = parseInt(order.total_bottles_ordered) || 1;
                                                        const percentage = Math.round((delivered / total) * 100);
                                                    %>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar <%= percentage === 100 ? 'bg-success' : percentage > 50 ? 'bg-info' : 'bg-warning' %>" 
                                                             role="progressbar" style="width: <%= percentage %>%">
                                                            <%= percentage %>%
                                                        </div>
                                                    </div>
                                                    <small class="text-muted">
                                                        <%= delivered %> / <%= total %> bottles
                                                    </small>
                                                </td>
                                                <td onclick="event.stopPropagation();">
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="/orders/<%= order.id %>" class="btn btn-outline-info" title="View Details">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <% if (order.order_status !== 'completed' && order.order_status !== 'cancelled') { %>
                                                            <a href="/orders/<%= order.id %>/edit" class="btn btn-outline-warning" title="Edit">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                        <% } %>
                                                        <button class="btn btn-outline-success" 
                                                                onclick="recordDelivery('<%= order.id %>')" title="Record Delivery">
                                                            <i class="fas fa-truck"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pagination -->
                            <% if (pagination && pagination.pages > 1) { %>
                                <nav class="mt-4">
                                    <ul class="pagination justify-content-center">
                                        <% if (pagination.page > 1) { %>
                                            <li class="page-item">
                                                <a class="page-link" href="?page=<%= pagination.page - 1 %>&search=<%= filters.search %>&order_status=<%= filters.order_status %>&order_type=<%= filters.order_type %>&bottle_type=<%= filters.bottle_type %>">
                                                    Previous
                                                </a>
                                            </li>
                                        <% } %>
                                        
                                        <% for (let i = Math.max(1, pagination.page - 2); i <= Math.min(pagination.pages, pagination.page + 2); i++) { %>
                                            <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                                                <a class="page-link" href="?page=<%= i %>&search=<%= filters.search %>&order_status=<%= filters.order_status %>&order_type=<%= filters.order_type %>&bottle_type=<%= filters.bottle_type %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                        <% } %>
                                        
                                        <% if (pagination.page < pagination.pages) { %>
                                            <li class="page-item">
                                                <a class="page-link" href="?page=<%= pagination.page + 1 %>&search=<%= filters.search %>&order_status=<%= filters.order_status %>&order_type=<%= filters.order_type %>&bottle_type=<%= filters.bottle_type %>">
                                                    Next
                                                </a>
                                            </li>
                                        <% } %>
                                    </ul>
                                </nav>
                            <% } %>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No orders found</h5>
                                <% if (filters.search || filters.order_status || filters.order_type || filters.bottle_type) { %>
                                    <p class="text-muted">Try adjusting your search criteria</p>
                                    <a href="/orders" class="btn btn-outline-primary">Clear Filters</a>
                                <% } else { %>
                                    <p class="text-muted">Start by creating your first order</p>
                                    <a href="/orders/add" class="btn btn-primary">
                                        <i class="fas fa-plus-circle"></i> Create First Order
                                    </a>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <!-- Delivery Recording Modal -->
    <div class="modal fade" id="deliveryModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-truck"></i> Record Delivery</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="deliveryForm">
                    <div class="modal-body">
                        <input type="hidden" id="delivery_order_id" name="order_id">
                        
                        <div class="mb-3">
                            <label for="delivered_date" class="form-label">Delivery Date</label>
                            <input type="date" class="form-control" id="delivered_date" name="delivered_date" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="quantity_delivered" class="form-label">Quantity Delivered</label>
                            <input type="number" class="form-control" id="quantity_delivered" name="quantity_delivered" min="1" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="delivery_person" class="form-label">Delivery Person</label>
                            <input type="text" class="form-control" id="delivery_person" name="delivery_person">
                        </div>
                        
                        <div class="mb-3">
                            <label for="delivery_vehicle" class="form-label">Vehicle</label>
                            <input type="text" class="form-control" id="delivery_vehicle" name="delivery_vehicle">
                        </div>
                        
                        <div class="mb-3">
                            <label for="delivery_notes" class="form-label">Delivery Notes</label>
                            <textarea class="form-control" id="delivery_notes" name="delivery_notes" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Record Delivery</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    
    <script>
        // Set today's date as default for delivery
        document.getElementById('delivered_date').value = new Date().toISOString().split('T')[0];

        // Record delivery function
        function recordDelivery(orderId) {
            document.getElementById('delivery_order_id').value = orderId;
            new bootstrap.Modal(document.getElementById('deliveryModal')).show();
        }

        // Handle delivery form submission
        document.getElementById('deliveryForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const orderId = document.getElementById('delivery_order_id').value;
            const formData = new FormData(this);
            
            fetch(`/orders/${orderId}/delivery`, {
                method: 'POST',
                body: formData
            })
            .then(response => response.text())
            .then(data => {
                // Close modal and reload page
                bootstrap.Modal.getInstance(document.getElementById('deliveryModal')).hide();
                location.reload();
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error recording delivery. Please try again.');
            });
        });

        // Table row highlighting
        document.addEventListener('DOMContentLoaded', function() {
            const tableRows = document.querySelectorAll('tbody tr[onclick]');
            tableRows.forEach(row => {
                row.addEventListener('mouseenter', function() {
                    this.style.backgroundColor = '#f8f9fa';
                });
                row.addEventListener('mouseleave', function() {
                    this.style.backgroundColor = '';
                });
            });
            
            // Load today's deliveries on page load
            loadTodayDeliveries();
        });
        
        // Load today's deliveries
        function loadTodayDeliveries() {
            const today = new Date().toISOString().split('T')[0];
            
            fetch(`/orders/api/due-today?date=${today}`)
                .then(response => response.json())
                .then(data => {
                    displayTodayDeliveries(data.orders || []);
                })
                .catch(error => {
                    console.error('Error loading today\'s deliveries:', error);
                    document.getElementById('todayDeliveriesContent').innerHTML = `
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i>
                            Unable to load today's deliveries. Please refresh the page.
                        </div>
                    `;
                });
        }
        
        function displayTodayDeliveries(deliveries) {
            const content = document.getElementById('todayDeliveriesContent');
            const count = document.getElementById('todayDeliveriesCount');
            
            count.textContent = deliveries.length;
            
            if (deliveries.length === 0) {
                content.innerHTML = `
                    <div class="text-center py-4">
                        <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                        <h6 class="text-muted">No deliveries scheduled for today</h6>
                        <p class="text-muted">All caught up! Enjoy your day.</p>
                    </div>
                `;
                return;
            }
            
            let html = '<div class="row">';
            
            deliveries.forEach(delivery => {
                const deliveryDate = new Date(delivery.next_delivery_date);
                const isOverdue = deliveryDate < new Date();
                
                html += `
                    <div class="col-md-6 col-lg-4 mb-3">
                        <div class="card border-start border-4 ${isOverdue ? 'border-danger' : 'border-warning'} h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title mb-0">
                                        <i class="fas fa-user text-primary"></i>
                                        ${delivery.customer_name || 'N/A'}
                                    </h6>
                                    <span class="badge ${isOverdue ? 'bg-danger' : 'bg-warning'}">
                                        ${isOverdue ? 'OVERDUE' : 'TODAY'}
                                    </span>
                                </div>
                                
                                <p class="text-muted small mb-2">
                                    <i class="fas fa-hashtag"></i> ${delivery.order_number}
                                    ${delivery.customer_phone ? `<span class="ms-2"><i class="fas fa-phone"></i> ${delivery.customer_phone}</span>` : ''}
                                </p>
                                
                                <div class="mb-2">
                                    <span class="text-muted">
                                        <i class="fas fa-bottles"></i> ${delivery.bottle_type} × ${delivery.quantity_per_delivery}
                                    </span>
                                </div>
                                
                                <div class="mb-3">
                                    <small class="text-muted">
                                        <i class="fas fa-map-marker-alt"></i>
                                        ${delivery.delivery_address || delivery.customer_address || 'Address not specified'}
                                    </small>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/orders/${delivery.id}" class="btn btn-outline-info">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <button class="btn btn-success" onclick="recordDelivery('${delivery.id}')">
                                            <i class="fas fa-truck"></i> Deliver
                                        </button>
                                    </div>
                                    <small class="text-muted">
                                        ${deliveryDate.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            content.innerHTML = html;
        }
        
        function refreshTodayDeliveries() {
            document.getElementById('todayDeliveriesContent').innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted mt-2">Refreshing deliveries...</p>
                </div>
            `;
            loadTodayDeliveries();
        }
    </script>
</body>
</html>