<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details - Driver</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        .driver-header { 
            background: linear-gradient(135deg, #007bff, #0056b3); 
        }
        .action-button {
            font-size: 1.5rem;
            font-weight: bold;
            padding: 20px;
            margin: 10px;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <!-- Simple driver navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark driver-header">
        <div class="container-fluid">
            <span class="navbar-brand">
                <i class="fas fa-truck me-2"></i>Order Details
            </span>
            <div class="ms-auto">
                <a href="/driver/dashboard" class="btn btn-outline-light me-2">
                    <i class="fas fa-arrow-left me-2"></i>Back
                </a>
                <a href="/auth/logout" class="btn btn-outline-light">
                    <i class="fas fa-sign-out-alt me-2"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <!-- Order Information -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h3><i class="fas fa-box"></i> Order Information</h3>
                    </div>
                    <div class="card-body" style="font-size: 1.2rem;">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong><i class="fas fa-user"></i> Customer:</strong><br>
                                <span style="font-size: 1.4rem;"><%= assignment.customer_name %></span></p>
                                
                                <p><strong><i class="fas fa-map-marker-alt"></i> Address:</strong><br>
                                <%= assignment.customer_address %></p>
                                
                                <p><strong><i class="fas fa-phone"></i> Phone:</strong><br>
                                <a href="tel:<%= assignment.customer_phone %>" class="btn btn-success">
                                    <i class="fas fa-phone"></i> Call <%= assignment.customer_phone %>
                                </a></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong><i class="fas fa-wine-bottle"></i> Bottles to Deliver:</strong><br>
                                <span class="badge bg-primary" style="font-size: 1.3rem;"><%= assignment.quantity_per_delivery || assignment.total_bottles %> bottles</span></p>
                                
                                <% if (assignment.time_slot) { %>
                                <p><strong><i class="fas fa-clock"></i> Time Slot:</strong><br>
                                <%= assignment.time_slot %></p>
                                <% } %>
                                
                                <p><strong><i class="fas fa-info-circle"></i> Status:</strong><br>
                                <span class="badge bg-<%= assignment.delivery_status === 'assigned' ? 'primary' : assignment.delivery_status === 'in_progress' ? 'warning' : assignment.delivery_status === 'delivered' ? 'success' : 'danger' %>" style="font-size: 1.1rem;">
                                    <%= assignment.delivery_status ? assignment.delivery_status.toUpperCase() : 'PENDING' %>
                                </span></p>
                            </div>
                        </div>
                        
                        <% if (assignment.special_instructions) { %>
                        <div class="row mt-3">
                            <div class="col-12">
                                <div class="alert alert-warning">
                                    <strong><i class="fas fa-exclamation-triangle"></i> Special Instructions:</strong><br>
                                    <%= assignment.special_instructions %>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-dark text-white">
                        <h3><i class="fas fa-cogs"></i> Delivery Actions</h3>
                    </div>
                    <div class="card-body text-center">
                        <% if (assignment.delivery_status === 'delivered') { %>
                            <div class="alert alert-success">
                                <h4><i class="fas fa-check-circle"></i> This delivery has been completed!</h4>
                            </div>
                            
                        <% } else if (assignment.delivery_status === 'failed') { %>
                            <div class="alert alert-danger">
                                <h4><i class="fas fa-times-circle"></i> This delivery was marked as failed.</h4>
                            </div>
                        <% } else { %>
                            <div class="row">
                                <div class="col-md-6">
                                    <button class="btn btn-success action-button w-100" 
                                            onclick="openBottleCodeModal('<%= assignment.id %>', '<%= assignment.quantity_per_delivery || assignment.total_bottles %>')">
                                        <i class="fas fa-check-circle fa-2x"></i><br>
                                        MARK DELIVERED
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <button class="btn btn-danger action-button w-100" 
                                            onclick="updateStatus('<%= assignment.id %>', 'failed')">
                                        <i class="fas fa-times-circle fa-2x"></i><br>
                                        MARK FAILED
                                    </button>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottle Code Input Modal (same as dispatch.ejs) -->
    <div class="modal fade" id="bottleCodeModal" tabindex="-1" aria-labelledby="bottleCodeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="bottleCodeModalLabel">
                        <i class="fas fa-qrcode"></i> Confirm Delivery - Enter Bottle Codes
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> 
                        <strong>Instructions:</strong> Please scan or enter the bottle codes for all bottles being delivered. 
                        Each bottle code should be 6 digits long.
                    </div>
                    
                    <form id="deliveryForm">
                        <input type="hidden" id="delivery_assignment_id" name="assignment_id">
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><strong>Bottles Required:</strong></label>
                                <span id="bottles_required" class="badge bg-primary fs-6">0</span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label"><strong>Bottles Entered:</strong></label>
                                <span id="bottles_entered" class="badge bg-secondary fs-6">0</span>
                            </div>
                        </div>

                        <div id="bottle_codes_container">
                            <!-- Bottle code inputs will be generated here -->
                        </div>

                        <div class="mb-3">
                            <label for="delivery_notes" class="form-label">Delivery Notes (Optional)</label>
                            <textarea class="form-control" id="delivery_notes" name="delivery_notes" rows="3" 
                                      placeholder="Any additional notes about the delivery..."></textarea>
                        </div>

                        <div class="alert alert-warning d-none" id="validation_alert">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span id="validation_message"></span>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-success" onclick="processDelivery()" id="confirm_delivery_btn">
                        <i class="fas fa-check"></i> Confirm Delivery
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Bottle Code Modal Functions (same as dispatch.ejs)
        function openBottleCodeModal(assignmentId, bottleQuantity) {
            document.getElementById('delivery_assignment_id').value = assignmentId;
            document.getElementById('bottles_required').textContent = bottleQuantity;
            document.getElementById('bottles_entered').textContent = '0';
            
            // Clear previous inputs
            const container = document.getElementById('bottle_codes_container');
            container.innerHTML = '';
            
            // Generate bottle code input fields
            for (let i = 1; i <= bottleQuantity; i++) {
                const div = document.createElement('div');
                div.className = 'mb-3';
                div.innerHTML = `
                    <label for="bottle_code_${i}" class="form-label">Bottle Code ${i}</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-qrcode"></i></span>
                        <input type="text" class="form-control bottle-code-input" 
                               id="bottle_code_${i}" name="bottle_codes[]" 
                               placeholder="Enter 6-digit bottle code" 
                               maxlength="6" pattern="[0-9]{6}" required
                               oninput="validateBottleCode(this, ${i})">
                        <button class="btn btn-outline-secondary" type="button" 
                                onclick="scanBottleCode(${i})" title="Scan QR Code">
                            <i class="fas fa-camera"></i>
                        </button>
                    </div>
                    <div class="invalid-feedback" id="bottle_error_${i}"></div>
                `;
                container.appendChild(div);
            }
            
            // Show modal
            new bootstrap.Modal(document.getElementById('bottleCodeModal')).show();
        }

        function validateBottleCode(input, index) {
            const code = input.value;
            const errorDiv = document.getElementById(`bottle_error_${index}`);
            
            // Remove non-numeric characters
            input.value = code.replace(/\D/g, '');
            
            // Validate length
            if (input.value.length === 6) {
                input.classList.remove('is-invalid');
                input.classList.add('is-valid');
                errorDiv.textContent = '';
            } else if (input.value.length > 0) {
                input.classList.remove('is-valid');
                input.classList.add('is-invalid');
                errorDiv.textContent = 'Bottle code must be 6 digits long';
            } else {
                input.classList.remove('is-valid', 'is-invalid');
                errorDiv.textContent = '';
            }
            
            // Update counter
            updateBottleCounter();
        }

        function updateBottleCounter() {
            const inputs = document.querySelectorAll('.bottle-code-input');
            const validInputs = Array.from(inputs).filter(input => 
                input.value.length === 6 && input.classList.contains('is-valid')
            );
            document.getElementById('bottles_entered').textContent = validInputs.length;
        }

        function scanBottleCode(index) {
            // Placeholder for QR code scanning functionality
            alert(`QR Code scanner for bottle ${index} - Feature coming soon!`);
        }

        function processDelivery() {
            const assignmentId = document.getElementById('delivery_assignment_id').value;
            const bottleInputs = document.querySelectorAll('.bottle-code-input');
            const deliveryNotes = document.getElementById('delivery_notes').value;
            const validationAlert = document.getElementById('validation_alert');
            const validationMessage = document.getElementById('validation_message');
            
            // Collect bottle codes
            const bottleCodes = [];
            let hasError = false;
            
            bottleInputs.forEach((input, index) => {
                const code = input.value.trim();
                if (code.length !== 6) {
                    hasError = true;
                    input.classList.add('is-invalid');
                } else {
                    bottleCodes.push(code);
                }
            });

            if (hasError) {
                validationMessage.textContent = 'Please enter all bottle codes (6 digits each)';
                validationAlert.classList.remove('d-none');
                return;
            }

            // Check for duplicate codes
            const uniqueCodes = [...new Set(bottleCodes)];
            if (uniqueCodes.length !== bottleCodes.length) {
                validationMessage.textContent = 'Duplicate bottle codes are not allowed';
                validationAlert.classList.remove('d-none');
                return;
            }

            validationAlert.classList.add('d-none');
            
            // Disable button and show loading
            const confirmBtn = document.getElementById('confirm_delivery_btn');
            confirmBtn.disabled = true;
            confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

            // Send delivery request to driver route instead of assignments route
            fetch(`/driver/order/${assignmentId}/delivered`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    bottle_codes: bottleCodes,
                    notes: deliveryNotes
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Close modal
                    bootstrap.Modal.getInstance(document.getElementById('bottleCodeModal')).hide();
                    
                    // Show success message
                    alert(`Delivery completed successfully with ${bottleCodes.length} bottles!`);
                    
                    // Redirect to driver dashboard
                    window.location.href = '/driver/dashboard';
                } else {
                    validationMessage.textContent = data.error || 'Failed to process delivery';
                    validationAlert.classList.remove('d-none');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                validationMessage.textContent = 'Failed to process delivery: ' + error.message;
                validationAlert.classList.remove('d-none');
            })
            .finally(() => {
                // Re-enable button
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = '<i class="fas fa-check"></i> Confirm Delivery';
            });
        }

        // Update status function for failed deliveries
        function updateStatus(assignmentId, newStatus) {
            if (newStatus === 'failed') {
                const reason = prompt('Why did the delivery fail? (Required)');
                if (!reason || !reason.trim()) {
                    return;
                }
                
                fetch(`/driver/order/${assignmentId}/failed`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ 
                        failure_reason: reason.trim() 
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Delivery marked as failed');
                        window.location.href = '/driver/dashboard';
                    } else {
                        alert('Error: ' + (data.error || 'Failed to update status'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to update status');
                });
            }
        }
    </script>

</body>
</html>