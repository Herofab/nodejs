<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details - Driver</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        .driver-header { 
            background: linear-gradient(135deg, #007bff, #0056b3); 
        }
        .action-button {
            font-size: 1.5rem;
            font-weight: bold;
            padding: 20px;
            margin: 10px;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <!-- Simple driver navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark driver-header">
        <div class="container-fluid">
            <span class="navbar-brand">
                <i class="fas fa-truck me-2"></i>Order Details
            </span>
            <div class="ms-auto">
                <a href="/driver/dashboard" class="btn btn-outline-light me-2">
                    <i class="fas fa-arrow-left me-2"></i>Back
                </a>
                <a href="/auth/logout" class="btn btn-outline-light">
                    <i class="fas fa-sign-out-alt me-2"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <!-- Order Information -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h3><i class="fas fa-box"></i> Order Information</h3>
                    </div>
                    <div class="card-body" style="font-size: 1.2rem;">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong><i class="fas fa-user"></i> Customer:</strong><br>
                                <span style="font-size: 1.4rem;"><%= assignment.customer_name %></span></p>
                                
                                <p><strong><i class="fas fa-map-marker-alt"></i> Address:</strong><br>
                                <%= assignment.customer_address %></p>
                                
                                <p><strong><i class="fas fa-phone"></i> Phone:</strong><br>
                                <a href="tel:<%= assignment.customer_phone %>" class="btn btn-success">
                                    <i class="fas fa-phone"></i> Call <%= assignment.customer_phone %>
                                </a></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong><i class="fas fa-wine-bottle"></i> Bottles to Deliver:</strong><br>
                                <span class="badge bg-primary" style="font-size: 1.3rem;"><%= assignment.total_bottles %> bottles</span></p>
                                
                                <% if (assignment.time_slot) { %>
                                <p><strong><i class="fas fa-clock"></i> Time Slot:</strong><br>
                                <%= assignment.time_slot %></p>
                                <% } %>
                                
                                <p><strong><i class="fas fa-info-circle"></i> Status:</strong><br>
                                <span class="badge bg-<%= assignment.delivery_status === 'assigned' ? 'primary' : assignment.delivery_status === 'in_progress' ? 'warning' : assignment.delivery_status === 'delivered' ? 'success' : 'danger' %>" style="font-size: 1.1rem;">
                                    <%= assignment.delivery_status ? assignment.delivery_status.toUpperCase() : 'PENDING' %>
                                </span></p>
                            </div>
                        </div>
                        
                        <% if (assignment.special_instructions) { %>
                        <div class="row mt-3">
                            <div class="col-12">
                                <div class="alert alert-warning">
                                    <strong><i class="fas fa-exclamation-triangle"></i> Special Instructions:</strong><br>
                                    <%= assignment.special_instructions %>
                                </div>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-dark text-white">
                        <h3><i class="fas fa-cogs"></i> Delivery Actions</h3>
                    </div>
                    <div class="card-body text-center">
                        <% if (assignment.delivery_status === 'delivered') { %>
                            <div class="alert alert-success">
                                <h4><i class="fas fa-check-circle"></i> This delivery has been completed!</h4>
                            </div>
                        <% } else if (assignment.delivery_status === 'failed') { %>
                            <div class="alert alert-danger">
                                <h4><i class="fas fa-times-circle"></i> This delivery was marked as failed.</h4>
                            </div>
                        <% } else { %>
                            <div class="row">
                                <div class="col-md-6">
                                    <button class="btn btn-success action-button w-100" onclick="markDelivered()">
                                        <i class="fas fa-check-circle fa-2x"></i><br>
                                        MARK DELIVERED
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <button class="btn btn-danger action-button w-100" onclick="markFailed()">
                                        <i class="fas fa-times-circle fa-2x"></i><br>
                                        MARK FAILED
                                    </button>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function markDelivered() {
            if (confirm('Mark this delivery as DELIVERED?')) {
                const notes = prompt('Add any delivery notes (optional):') || '';
                
                fetch('/driver/order/<%= assignment.id %>/delivered', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        notes: notes,
                        delivered_bottles: <%= assignment.total_bottles %>
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Delivery marked as completed!');
                        window.location.href = '/driver/dashboard';
                    } else {
                        alert('Error: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error marking delivery as completed');
                });
            }
        }

        function markFailed() {
            const reason = prompt('Why did the delivery fail? (Required)');
            if (reason && reason.trim()) {
                fetch('/driver/order/<%= assignment.id %>/failed', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        failure_reason: reason.trim()
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Delivery marked as failed');
                        window.location.href = '/driver/dashboard';
                    } else {
                        alert('Error: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error marking delivery as failed');
                });
            }
        }
    </script>

</body>
</html>