<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
        .order-card {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            margin-bottom: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .order-card:hover {
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            transform: translateY(-2px);
        }
        .driver-header { 
            background: linear-gradient(135deg, #007bff, #0056b3); 
        }
        .status-pending { border-left: 4px solid #007bff; }
        .status-in_progress { border-left: 4px solid #fd7e14; }
        .status-delivered { border-left: 4px solid #28a745; }
        .status-failed { border-left: 4px solid #dc3545; }
    </style>
</head>
<body>
    <!-- Simple driver navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark driver-header">
        <div class="container-fluid">
            <span class="navbar-brand">
                <i class="fas fa-truck me-2"></i>Driver Dashboard
            </span>
            <div class="ms-auto">
                <a href="/auth/logout" class="btn btn-outline-light">
                    <i class="fas fa-sign-out-alt me-2"></i>Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <!-- Welcome header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h2><i class="fas fa-truck fa-2x"></i></h2>
                        <h3>Welcome <%= user.email.split('@')[0] %>!</h3>
                        <p class="mb-0">Today's Date: <%= new Date(todayDate).toLocaleDateString() %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders List -->
        <div class="row">
            <div class="col-12">
                <h4><i class="fas fa-list"></i> Today's Deliveries</h4>
                
                <% if (orders.length === 0) { %>
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle fa-2x mb-3"></i>
                        <h5>No deliveries assigned for today</h5>
                        <p>Contact your supervisor if you expect to have deliveries.</p>
                    </div>
                <% } else { %>
                    <% orders.forEach((order, index) => { %>
                        <div class="order-card status-<%= order.status %> p-3" onclick="openOrder('<%= order.assignmentId %>')">
                            <div class="row align-items-center">
                                <div class="col-md-1">
                                    <div class="text-center">
                                        <h3 class="mb-0">#<%= index + 1 %></h3>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <h5 class="mb-1"><i class="fas fa-user"></i> <%= order.customerName %></h5>
                                    <p class="mb-1"><i class="fas fa-map-marker-alt"></i> <%= order.customerAddress %></p>
                                    <p class="mb-0"><i class="fas fa-phone"></i> <%= order.customerPhone %></p>
                                </div>
                                <div class="col-md-3">
                                    <p class="mb-1"><strong><i class="fas fa-wine-bottle"></i> Bottles:</strong> <%= order.totalBottles %></p>
                                    <% if (order.timeSlot) { %>
                                        <p class="mb-0"><strong><i class="fas fa-clock"></i> Time:</strong> <%= order.timeSlot %></p>
                                    <% } %>
                                </div>
                                <div class="col-md-2 text-center">
                                    <span class="badge bg-<%= order.status === 'pending' ? 'primary' : order.status === 'in_progress' ? 'warning' : order.status === 'delivered' ? 'success' : 'danger' %> fs-6">
                                        <%= order.status.toUpperCase() %>
                                    </span>
                                    <br><br>
                                    <i class="fas fa-arrow-right text-primary fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Bootstrap JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openOrder(assignmentId) {
            window.location.href = '/driver/order/' + assignmentId;
        }
    </script>

</body>
</html>